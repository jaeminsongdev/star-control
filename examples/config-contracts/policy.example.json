{
  "schema_version": "1.0.0",
  "policy_id": "default-safety",
  "description": "Default repository safety policy.",
  "applies_to": [
    "route",
    "implement",
    "validate"
  ],
  "rules": [
    {
      "id": "dependency.requires_approval",
      "severity": "approval_required",
      "description": "Dependency changes require approval.",
      "match": {
        "change_type": "dependency"
      },
      "action": "request_approval"
    }
  ]
}
