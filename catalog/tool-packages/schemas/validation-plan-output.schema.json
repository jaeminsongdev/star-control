{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schema/core/validation-plan-output-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "validation_plan_id",
    "capability_level",
    "project_key",
    "revision",
    "changed_files",
    "direct_units",
    "reverse_consumers",
    "profile",
    "checks",
    "uncertainties",
    "independent_review",
    "readiness",
    "evidence_flow",
    "input_fingerprint",
    "plan_fingerprint"
  ],
  "properties": {
    "schema_id": { "const": "star.validation-plan" },
    "schema_version": { "const": 1 },
    "validation_plan_id": {
      "type": "string",
      "pattern": "^vpl_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "capability_level": { "const": "tracked_path_precursor" },
    "project_key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{0,127}$"
    },
    "revision": { "type": "string", "minLength": 1, "maxLength": 128 },
    "changed_files": { "type": "array", "items": { "type": "object" } },
    "direct_units": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "reverse_consumers": { "type": "array", "items": { "type": "object" } },
    "profile": { "type": "object" },
    "checks": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "uncertainties": { "type": "array", "items": { "type": "object" } },
    "independent_review": { "type": "object" },
    "readiness": { "enum": ["ready", "human_review", "blocked"] },
    "evidence_flow": {
      "const": [
        "validation_plan",
        "validation_run_diagnostic_result",
        "gate_decision",
        "evidence_bundle",
        "ai_compressed_summary"
      ]
    },
    "input_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "plan_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
