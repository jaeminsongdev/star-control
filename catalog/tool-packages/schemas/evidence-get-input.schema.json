{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schema/core/evidence-get-input-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["project_key", "evidence_ref"],
  "properties": {
    "project_key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{0,127}$"
    },
    "evidence_ref": {
      "type": "string",
      "pattern": "^target/validation/[A-Za-z0-9._-]+/report\\.json$"
    }
  }
}
