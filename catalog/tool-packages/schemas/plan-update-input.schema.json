{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schema/core/plan-update-input-v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["goal_id", "expected_revision", "items"],
  "properties": {
    "goal_id": { "type": "string", "pattern": "^gol_[0-9A-HJKMNP-TV-Z]{26}$" },
    "expected_revision": { "type": "integer", "minimum": 1 },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": { "$ref": "#/$defs/plan_item" }
    }
  },
  "$defs": {
    "plan_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "step", "status"],
      "properties": {
        "item_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
        "step": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "status": { "enum": ["pending", "in_progress", "completed", "blocked"] }
      }
    }
  }
}
