{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CorpusCase",
  "type": "object",
  "required": [
    "case_id",
    "rule_id",
    "should_fail",
    "expected"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "rule_id": {
      "type": "string"
    },
    "should_fail": {
      "type": "boolean"
    },
    "input_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected": {
      "type": "object"
    },
    "notes": {
      "type": "string"
    }
  }
}
