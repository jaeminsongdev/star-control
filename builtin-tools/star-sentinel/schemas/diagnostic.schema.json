{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Star Sentinel Diagnostic",
  "type": "object",
  "required": [
    "schema_version",
    "diagnostic_id",
    "rule_id",
    "severity",
    "message",
    "locations"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "diagnostic_id": {
      "type": "string"
    },
    "rule_id": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "block",
        "warn",
        "info"
      ]
    },
    "message": {
      "type": "string"
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "line": {
            "type": "integer"
          },
          "symbol": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendation": {
      "type": "string"
    }
  }
}
