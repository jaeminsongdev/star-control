{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Star Sentinel Approval Decision",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "decision",
    "reasons",
    "diagnostics"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "task_id": {
      "type": "string"
    },
    "decision": {
      "enum": [
        "AUTO_PASS",
        "HUMAN_REVIEW",
        "BLOCK"
      ]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "required_human_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
