{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Star Sentinel Review Pack",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "decision",
    "summary",
    "changed_files",
    "risks",
    "validations",
    "unverified_claims",
    "questions_for_human"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "task_id": {
      "type": "string"
    },
    "decision": {
      "enum": [
        "AUTO_PASS",
        "HUMAN_REVIEW",
        "BLOCK"
      ]
    },
    "summary": {
      "type": "string"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "command",
          "result"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "result": {
            "type": "string"
          }
        }
      }
    },
    "unverified_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "questions_for_human": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generated_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_pack_markdown": {
      "type": "string"
    }
  }
}
