{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Star Sentinel Validation Run",
  "type": "object",
  "required": [
    "schema_version",
    "validation_id",
    "task_id",
    "command",
    "status",
    "started_at",
    "finished_at",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "validation_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "profile": {
      "type": "string"
    },
    "status": {
      "enum": [
        "passed",
        "failed",
        "skipped",
        "blocked",
        "error"
      ]
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
