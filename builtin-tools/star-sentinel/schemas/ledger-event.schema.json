{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Star Sentinel Ledger Event",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "task_id",
    "event_type",
    "stage",
    "severity",
    "message",
    "created_at",
    "source"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "event_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "event_type": {
      "enum": [
        "TASK_CREATED",
        "POLICY_CHECKED",
        "VALIDATION_RECORDED",
        "GATE_DECIDED",
        "REVIEW_PACK_CREATED",
        "ARTIFACT_WRITTEN",
        "ERROR_RECORDED"
      ]
    },
    "stage": {
      "enum": [
        "route",
        "plan",
        "design",
        "implement",
        "validate",
        "review",
        "polish",
        "report"
      ]
    },
    "severity": {
      "enum": [
        "info",
        "warn",
        "block"
      ]
    },
    "message": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "enum": [
            "core",
            "provider",
            "tool",
            "human",
            "ci"
          ]
        },
        "name": {
          "type": "string"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
