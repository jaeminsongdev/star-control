{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/provider-run-result.schema.json",
  "title": "Star-Control ProviderRunResult",
  "type": "object",
  "required": [
    "schema_version",
    "provider_instance_id",
    "job_id",
    "stage",
    "status",
    "summary",
    "changed_files",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "provider_instance_id": {
      "type": "string",
      "minLength": 1
    },
    "job_id": {
      "type": "string",
      "pattern": "^J-[0-9]{4,}$"
    },
    "stage": {
      "type": "string",
      "enum": [
        "route",
        "plan",
        "design",
        "implement",
        "validate",
        "review",
        "polish",
        "report"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failed",
        "blocked",
        "cancelled",
        "timeout",
        "error"
      ]
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": "string"
    },
    "stdout_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "stderr_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "summary": {
      "type": "string"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metrics": {
      "type": "object"
    },
    "error": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
