{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/report.schema.json",
  "title": "Star-Control ReportSpec",
  "type": "object",
  "required": [
    "job_id",
    "stage",
    "status",
    "changed_files",
    "validation",
    "risks",
    "next_step"
  ],
  "properties": {
    "job_id": {
      "type": "string"
    },
    "stage": {
      "type": "string"
    },
    "status": {
      "enum": [
        "DONE",
        "FAILED",
        "BLOCKED",
        "NEEDS_APPROVAL",
        "NEEDS_REVIEW"
      ]
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands_run": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string"
          },
          "result": {
            "type": "string"
          }
        }
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_step": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
