{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/route.schema.json",
  "title": "Star-Control RouteSpec",
  "type": "object",
  "required": [
    "schema_version",
    "job_id",
    "summary",
    "size",
    "risk",
    "policy_profile",
    "decision",
    "change_types",
    "routing_reasons",
    "stages",
    "assignments",
    "requires_user_approval",
    "approval_reasons",
    "workspecs"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "job_id": {
      "type": "string",
      "pattern": "^J-[0-9]{4,}$"
    },
    "summary": {
      "type": "string"
    },
    "size": {
      "type": "string",
      "enum": [
        "SMALL",
        "MEDIUM",
        "LARGE",
        "CRITICAL"
      ]
    },
    "risk": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "policy_profile": {
      "type": "string",
      "enum": [
        "quick",
        "near",
        "full",
        "security",
        "release",
        "validator"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "AUTO_PASS",
        "HUMAN_REVIEW",
        "BLOCK"
      ]
    },
    "change_types": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "routing_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stages": {
      "type": "array",
      "items": {
        "enum": [
          "route",
          "plan",
          "design",
          "implement",
          "validate",
          "review",
          "polish",
          "report"
        ]
      }
    },
    "assignments": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "role",
          "provider"
        ],
        "properties": {
          "role": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "profile": {
            "type": "string"
          }
        }
      }
    },
    "requires_user_approval": {
      "type": "boolean"
    },
    "approval_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workspecs": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
