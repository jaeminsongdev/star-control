{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/run-state.schema.json",
  "title": "Star-Control RunState",
  "type": "object",
  "required": [
    "schema_version",
    "job_id",
    "state",
    "current_stage",
    "workers",
    "next_action"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "job_id": {
      "type": "string"
    },
    "state": {
      "type": "string",
      "enum": [
        "REQUESTED",
        "ROUTING",
        "ROUTED",
        "PLANNING",
        "PLANNED",
        "WAITING_APPROVAL",
        "IMPLEMENTING",
        "IMPLEMENTED",
        "VALIDATING",
        "VALIDATED",
        "REVIEWING",
        "REVIEWED",
        "POLISHING",
        "POLISHED",
        "REPORTING",
        "DONE",
        "FAILED",
        "BLOCKED",
        "CANCELLED"
      ]
    },
    "current_stage": {
      "type": "string",
      "enum": [
        "route",
        "plan",
        "design",
        "implement",
        "validate",
        "review",
        "polish",
        "report"
      ]
    },
    "threads": {
      "type": "object"
    },
    "workers": {
      "type": "object"
    },
    "artifacts": {
      "type": "object"
    },
    "next_action": {
      "type": "string"
    },
    "budget": {
      "type": "object"
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
