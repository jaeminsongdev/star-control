{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/cost-metric.schema.json",
  "title": "Star-Control CostMetric",
  "type": "object",
  "required": [
    "schema_version",
    "job_id",
    "stage",
    "provider_instance_id",
    "estimated_cost",
    "currency",
    "wall_time_ms"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "job_id": {
      "type": "string",
      "pattern": "^J-[0-9]{4,}$"
    },
    "stage": {
      "type": "string"
    },
    "provider_instance_id": {
      "type": "string"
    },
    "input_tokens": {
      "type": "integer"
    },
    "output_tokens": {
      "type": "integer"
    },
    "estimated_cost": {
      "type": "number"
    },
    "currency": {
      "type": "string"
    },
    "wall_time_ms": {
      "type": "integer"
    },
    "quota_remaining": {
      "type": [
        "number",
        "null"
      ]
    }
  }
}
