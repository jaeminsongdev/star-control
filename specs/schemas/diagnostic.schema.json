{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Diagnostic",
  "type": "object",
  "required": [
    "rule_id",
    "severity",
    "message",
    "location",
    "fingerprint"
  ],
  "properties": {
    "rule_id": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "info",
        "warning",
        "human_review",
        "block"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "message": {
      "type": "string"
    },
    "location": {
      "type": "object",
      "properties": {
        "file": {
          "type": "string"
        },
        "line": {
          "type": "integer"
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "remediation": {
      "type": "string"
    },
    "fingerprint": {
      "type": "string"
    }
  }
}
