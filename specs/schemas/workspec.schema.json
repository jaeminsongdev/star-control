{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/workspec.schema.json",
  "title": "Star-Control WorkSpec",
  "type": "object",
  "required": [
    "schema_version",
    "job_id",
    "stage",
    "role",
    "provider",
    "provider_instance",
    "project_root",
    "goal",
    "allowed_scope",
    "forbidden_actions",
    "required_outputs"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "job_id": {
      "type": "string",
      "pattern": "^J-[0-9]{4,}$"
    },
    "stage": {
      "type": "string",
      "enum": [
        "route",
        "plan",
        "design",
        "implement",
        "validate",
        "review",
        "polish",
        "report"
      ]
    },
    "role": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "provider_instance": {
      "type": "string"
    },
    "project_root": {
      "type": "string"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "allowed_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "dependency_install",
          "dependency_change",
          "file_delete",
          "bulk_move",
          "test_delete",
          "test_skip_only_ignore",
          "assertion_weakening",
          "workflow_change",
          "schema_breaking_change",
          "validator_self_bypass",
          "sensitive_data_output",
          "credential_change",
          "external_account_change",
          "release_publish",
          "deploy"
        ]
      }
    },
    "context_pack": {
      "type": "object"
    },
    "required_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
