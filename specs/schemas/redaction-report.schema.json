{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/redaction-report.schema.json",
  "title": "Star-Control RedactionReport",
  "type": "object",
  "required": [
    "schema_version",
    "job_id",
    "artifact_path",
    "redacted",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "job_id": {
      "type": "string",
      "pattern": "^J-[0-9]{4,}$"
    },
    "artifact_path": {
      "type": "string"
    },
    "redacted": {
      "type": "boolean"
    },
    "placeholder": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "path"
        ],
        "properties": {
          "kind": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "action": {
            "type": "string"
          }
        }
      }
    }
  }
}
