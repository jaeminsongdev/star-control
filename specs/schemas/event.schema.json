{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/event.schema.json",
  "title": "Star-Control CoreEvent",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "job_id",
    "type",
    "created_at",
    "message"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "job_id": {
      "type": "string",
      "pattern": "^J-[0-9]{4,}$"
    },
    "type": {
      "type": "string",
      "enum": [
        "JOB_CREATED",
        "STATE_CHANGED",
        "STAGE_ENTERED",
        "STAGE_COMPLETED",
        "ROUTE_CREATED",
        "WORKSPEC_CREATED",
        "ARTIFACT_WRITTEN",
        "PROVIDER_STARTED",
        "PROVIDER_FINISHED",
        "VALIDATION_RECORDED",
        "GATE_DECIDED",
        "REVIEW_PACK_CREATED",
        "APPROVAL_REQUESTED",
        "APPROVAL_RECORDED",
        "ERROR_RECORDED"
      ]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "artifact_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "details": {
      "type": "object"
    }
  }
}
