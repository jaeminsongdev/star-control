{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/provider-registry.schema.json",
  "title": "Star-Control ProviderRegistry",
  "type": "object",
  "required": [
    "schema_version",
    "providers"
  ],
  "properties": {
    "schema_version": {
      "type": [
        "string",
        "number"
      ]
    },
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "manifest",
          "capabilities"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^provider\\.[a-z0-9][a-z0-9.-]*$"
          },
          "manifest": {
            "type": "string",
            "minLength": 1
          },
          "capabilities": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
