{
  "$defs": {
    "DevelopmentProfileDefinitionRefV1": {
      "additionalProperties": false,
      "properties": {
        "definition_hash": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "profile_ref": {
          "$ref": "#/$defs/DevelopmentProfileRefV1"
        }
      },
      "required": [
        "profile_ref",
        "definition_hash"
      ],
      "type": "object"
    },
    "DevelopmentProfileRefV1": {
      "additionalProperties": false,
      "properties": {
        "profile_id": {
          "type": "string"
        },
        "profile_version": {
          "type": "string"
        }
      },
      "required": [
        "profile_id",
        "profile_version"
      ],
      "type": "object"
    },
    "ProfileApprovalCheckpointV1": {
      "enum": [
        "network",
        "download",
        "debug_attach",
        "dependency_change",
        "patch_apply",
        "migration_execute",
        "destructive_migration",
        "unknown_field_loss",
        "cross_project_effect",
        "language_cutover",
        "remote_write",
        "release_publish"
      ],
      "type": "string"
    },
    "ProfileBaselinePolicyV1": {
      "enum": [
        "off",
        "report_only",
        "ratchet_new",
        "ratchet_new_and_worsened",
        "clean_only"
      ],
      "type": "string"
    },
    "ProfileEffectClassV1": {
      "enum": [
        "read",
        "plan",
        "validate",
        "local_state_write",
        "workspace_mutation",
        "network_read",
        "remote_write",
        "publish"
      ],
      "type": "string"
    },
    "ProfileGatePhaseV1": {
      "enum": [
        "during_stage",
        "stage_exit",
        "goal_exit",
        "patch_pre_apply",
        "patch_post_apply",
        "merge",
        "migration_pre_execute",
        "migration_post_execute",
        "migration_post_rollback",
        "performance_compare",
        "language_cutover",
        "release",
        "release_preflight",
        "release_build",
        "release_verify",
        "release_package",
        "release_install_lifecycle",
        "release_ready",
        "release_publish_preflight",
        "release_publish_verify"
      ],
      "type": "string"
    },
    "ProfilePermissionFloorV1": {
      "enum": [
        "local_read_only",
        "exact_prompt",
        "exact_durable_approval",
        "deny_external"
      ],
      "type": "string"
    },
    "ProfileReviewFloorV1": {
      "enum": [
        "none",
        "human_semantic",
        "independent_human",
        "block"
      ],
      "type": "string"
    },
    "ProfileReviewPolicyV1": {
      "additionalProperties": false,
      "properties": {
        "cli_only": {
          "$ref": "#/$defs/ProfileReviewFloorV1"
        },
        "codex_managed": {
          "$ref": "#/$defs/ProfileReviewFloorV1"
        }
      },
      "required": [
        "cli_only",
        "codex_managed"
      ],
      "type": "object"
    },
    "ProfileStabilityPolicyV1": {
      "enum": [
        "report_flaky",
        "human_review_flaky",
        "block_required_flaky"
      ],
      "type": "string"
    },
    "ProfileSuppressionPolicyV1": {
      "enum": [
        "exact",
        "bounded_expiring",
        "approved_expiring"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.development-profile-resolution:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "allowed_effect_classes": {
      "items": {
        "$ref": "#/$defs/ProfileEffectClassV1"
      },
      "type": "array"
    },
    "always_run_for": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "approval_checkpoints": {
