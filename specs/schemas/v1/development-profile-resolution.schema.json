      },
      "type": "array"
    },
    "evidence_requirements": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "gate_phases": {
      "items": {
        "$ref": "#/$defs/ProfileGatePhaseV1"
      },
      "type": "array"
    },
    "optional_check_families": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "parent_closure": {
      "items": {
        "$ref": "#/$defs/DevelopmentProfileRefV1"
      },
      "type": "array"
    },
    "permission_actions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "permission_floor": {
      "$ref": "#/$defs/ProfilePermissionFloorV1"
    },
    "profile_resolution_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "required_check_families": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "required_rule_families": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "review_policy": {
      "$ref": "#/$defs/ProfileReviewPolicyV1"
    },
    "route_hints": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "schema_id": {
      "const": "star.development-profile-resolution",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "selected_profiles": {
      "items": {
        "$ref": "#/$defs/DevelopmentProfileRefV1"
      },
      "type": "array"
    },
    "stability_policy": {
      "$ref": "#/$defs/ProfileStabilityPolicyV1"
    },
    "stage_refs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "suppression_policy": {
      "$ref": "#/$defs/ProfileSuppressionPolicyV1"
    },
    "triggers": {
