    },
    "claim_policy": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "context_rules": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "corpus_requirements": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "default_stop_states": {
      "items": {
        "type": "string"
      },
      "type": "array"
