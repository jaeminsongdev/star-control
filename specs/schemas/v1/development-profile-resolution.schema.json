    "claim_policy",
    "stability_policy",
    "review_policy",
    "evidence_requirements",
    "corpus_requirements",
    "approval_checkpoints",
    "allowed_effect_classes",
    "permission_floor",
    "default_stop_states",
    "profile_resolution_fingerprint"
