{
  "$defs": {
    "BackupStoreTarget": {
      "additionalProperties": false,
      "properties": {
        "generation": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "management_store_version": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "scope": {
          "$ref": "#/$defs/StoreScope"
        },
        "store_id": {
          "pattern": "^mst_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "store_revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "scope",
        "store_id",
        "generation",
        "management_store_version",
        "store_revision"
      ],
      "type": "object"
    },
    "ProjectStorePoint": {
      "additionalProperties": false,
      "properties": {
        "point": {
          "$ref": "#/$defs/StorePoint"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        }
      },
      "required": [
        "project_id",
        "point"
      ],
      "type": "object"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "StorePoint": {
      "additionalProperties": false,
      "properties": {
        "generation": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "store_id": {
          "pattern": "^mst_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        }
      },
      "required": [
        "store_id",
        "generation",
        "revision"
      ],
      "type": "object"
    },
    "StoreScope": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "global",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "project",
              "type": "string"
            },
            "project_id": {
              "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "project_id"
          ],
          "type": "object"
        }
      ]
    },
    "StoreVersionVector": {
      "additionalProperties": false,
      "properties": {
        "global": {
          "$ref": "#/$defs/StorePoint"
        },
        "projects": {
          "items": {
            "$ref": "#/$defs/ProjectStorePoint"
          },
          "type": "array"
        }
      },
      "required": [
        "global",
        "projects"
      ],
      "type": "object"
    }
  },
  "$id": "urn:star-control:schema:star.management-backup-plan:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "backup_set_id": {
      "pattern": "^bks_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "destination_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "plan_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "schema_id": {
      "const": "star.management-backup-plan",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "source_active_set_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "source_store_vector": {
      "$ref": "#/$defs/StoreVersionVector"
    },
    "stores": {
      "items": {
        "$ref": "#/$defs/BackupStoreTarget"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "backup_set_id",
    "created_at",
    "source_active_set_fingerprint",
    "source_store_vector",
    "destination_fingerprint",
    "stores",
    "plan_fingerprint"
  ],
  "title": "BackupPlan",
  "type": "object"
}