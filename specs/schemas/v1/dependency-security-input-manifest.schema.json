{
  "$defs": {
    "CoverageState": {
      "enum": [
        "complete",
        "partial",
        "unverified"
      ],
      "type": "string"
    },
    "ManifestObservation": {
      "additionalProperties": false,
      "properties": {
        "completeness": {
          "$ref": "#/$defs/CoverageState"
        },
        "content_sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "ecosystem": {
          "type": "string"
        },
        "logical_path": {
          "type": "string"
        },
        "manifest_kind": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "relation": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "ecosystem",
        "manifest_kind",
        "logical_path",
        "content_sha256",
        "owner",
        "completeness"
      ],
      "type": "object"
    },
    "ObservationState": {
      "enum": [
        "present",
        "missing",
        "version_mismatch",
        "unknown"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "ToolchainObservation": {
      "additionalProperties": false,
      "properties": {
        "declared_range": {
          "type": [
            "string",
            "null"
          ]
        },
        "discovered_from": {
          "type": "string"
        },
        "evidence_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "executable_fingerprint": {
          "anyOf": [
            {
              "$ref": "#/$defs/Sha256Hash"
            },
            {
              "type": "null"
            }
          ]
        },
        "observed_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "state": {
          "$ref": "#/$defs/ObservationState"
        },
        "toolchain_id": {
          "type": "string"
        }
      },
      "required": [
        "toolchain_id",
        "discovered_from",
        "state"
      ],
      "type": "object"
    }
  },
  "$id": "urn:star-control:schema:star.dependency-security-input-manifest:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "completeness": {
      "$ref": "#/$defs/CoverageState"
    },
    "content_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "environment_snapshot_ref": {
      "type": "string"
    },
    "limitations": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "manifest_id": {
      "type": "string"
    },
    "manifest_observations": {
      "items": {
        "$ref": "#/$defs/ManifestObservation"
      },
      "type": "array"
    },
    "project_id": {
      "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "schema_id": {
      "const": "star.dependency-security-input-manifest",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "subject_revision": {
      "type": "string"
    },
    "toolchain_observations": {
      "items": {
        "$ref": "#/$defs/ToolchainObservation"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "manifest_id",
    "project_id",
    "subject_revision",
    "environment_snapshot_ref",
    "manifest_observations",
    "toolchain_observations",
    "completeness",
    "content_fingerprint"
  ],
  "title": "DependencySecurityInputManifest",
  "type": "object"
}