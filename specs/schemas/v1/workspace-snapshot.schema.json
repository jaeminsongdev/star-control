{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "log",
        "report",
        "diff",
        "screenshot",
        "trace",
        "manifest",
        "input",
        "output",
        "checkpoint",
        "change_set",
        "review_pack"
      ],
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^art_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "media_type": {
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/ProducerRef"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": [
            "string",
            "null"
          ]
        },
        "redaction_status": {
          "$ref": "#/$defs/RedactionStatus"
        },
        "relative_path": {
          "type": "string"
        },
        "retention_class": {
          "$ref": "#/$defs/RetentionClass"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source_artifact_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "artifact_id",
        "kind",
        "relative_path",
        "media_type",
        "size_bytes",
        "sha256",
        "created_at",
        "producer",
        "redaction_status",
        "retention_class"
      ],
      "type": "object"
    },
    "Completeness": {
      "enum": [
        "complete",
        "partial",
        "unverified"
      ],
      "type": "string"
    },
    "ProducerRef": {
      "additionalProperties": false,
      "properties": {
        "build_id": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "product_version": {
          "type": "string"
        }
      },
      "required": [
        "component",
        "product_version",
        "build_id",
        "platform"
      ],
      "type": "object"
    },
    "RedactionStatus": {
      "enum": [
        "not_needed",
        "redacted",
        "quarantined",
        "unknown"
      ],
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "temporary",
        "run",
        "evidence",
        "hold"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.workspace-snapshot:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "captured_at": {
      "format": "date-time",
      "type": "string"
    },
    "completeness": {
      "$ref": "#/$defs/Completeness"
    },
    "dirty_summary": {
      "additionalProperties": {
        "format": "uint64",
        "minimum": 0,
        "type": "integer"
      },
      "type": "object"
    },
    "entries_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "entries_manifest_ref": {
      "$ref": "#/$defs/ArtifactRef"
    },
    "ignored_policy": {
      "type": "string"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "project_id": {
      "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "project_revision_id": {
      "pattern": "^prv_[a-z2-7]{52}$",
      "type": "string"
    },
    "schema_id": {
      "const": "star.workspace-snapshot",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "scope": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "symlink_policy": {
      "type": "string"
    },
    "workspace_snapshot_id": {
      "pattern": "^wsp_[a-z2-7]{52}$",
      "type": "string"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "workspace_snapshot_id",
    "project_id",
    "project_revision_id",
    "scope",
    "entries_manifest_ref",
    "entries_fingerprint",
    "dirty_summary",
    "ignored_policy",
    "symlink_policy",
    "captured_at",
    "completeness",
    "limitations"
  ],
  "title": "WorkspaceSnapshot",
  "type": "object"
}