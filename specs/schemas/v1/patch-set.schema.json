{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "log",
        "report",
        "diff",
        "screenshot",
        "trace",
        "manifest",
        "input",
        "output",
        "checkpoint",
        "change_set",
        "review_pack"
      ],
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^art_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "media_type": {
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/ProducerRef"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": [
            "string",
            "null"
          ]
        },
        "redaction_status": {
          "$ref": "#/$defs/RedactionStatus"
        },
        "relative_path": {
          "type": "string"
        },
        "retention_class": {
          "$ref": "#/$defs/RetentionClass"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source_artifact_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "artifact_id",
        "kind",
        "relative_path",
        "media_type",
        "size_bytes",
        "sha256",
        "created_at",
        "producer",
        "redaction_status",
        "retention_class"
      ],
      "type": "object"
    },
    "FileOperationKind": {
      "enum": [
        "add",
        "modify",
        "delete",
        "rename"
      ],
      "type": "string"
    },
    "PatchFileOperation": {
      "additionalProperties": false,
      "properties": {
        "after_mode": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "after_sha256": {
          "anyOf": [
            {
              "$ref": "#/$defs/Sha256Hash"
            },
            {
              "type": "null"
            }
          ]
        },
        "before_mode": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "before_sha256": {
          "anyOf": [
            {
              "$ref": "#/$defs/Sha256Hash"
            },
            {
              "type": "null"
            }
          ]
        },
        "kind": {
          "$ref": "#/$defs/FileOperationKind"
        },
        "operation_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "path": {
          "minLength": 1,
          "pattern": "^[^/\\\\:\\u0000]+(?:/[^/\\\\:\\u0000]+)*$",
          "type": "string"
        },
        "rename_from": {
          "minLength": 1,
          "pattern": "^[^/\\\\:\\u0000]+(?:/[^/\\\\:\\u0000]+)*$",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "kind",
        "path",
        "operation_fingerprint"
      ],
      "type": "object"
    },
    "PatchSetStatus": {
      "enum": [
        "proposed",
        "applied",
        "partially_applied",
        "failed",
        "reverted"
      ],
      "type": "string"
    },
    "ProducerRef": {
      "additionalProperties": false,
      "properties": {
        "build_id": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "product_version": {
          "type": "string"
        }
      },
      "required": [
        "component",
        "product_version",
        "build_id",
        "platform"
      ],
      "type": "object"
    },
    "RedactionStatus": {
      "enum": [
        "not_needed",
        "redacted",
        "quarantined",
        "unknown"
      ],
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "temporary",
        "run",
        "evidence",
        "hold"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.patch-set:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "affected_finding_ids": {
      "items": {
        "pattern": "^fnd_[a-z2-7]{52}$",
        "type": "string"
      },
      "type": "array"
    },
    "applied_workspace_snapshot_id": {
      "pattern": "^wsp_[a-z2-7]{52}$",
      "type": [
        "string",
        "null"
      ]
    },
    "base_workspace_snapshot_id": {
      "pattern": "^wsp_[a-z2-7]{52}$",
      "type": "string"
    },
    "change_plan_id": {
      "pattern": "^cpl_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "change_plan_revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "expected_result_fingerprint": {
      "anyOf": [
        {
          "$ref": "#/$defs/Sha256Hash"
        },
        {
          "type": "null"
        }
      ]
    },
    "operations": {
      "items": {
        "$ref": "#/$defs/PatchFileOperation"
      },
      "type": "array"
    },
    "patch_artifact_refs": {
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "type": "array"
    },
    "patch_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "patch_set_id": {
      "pattern": "^pat_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "project_id": {
      "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "rollback_artifact_refs": {
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "type": "array"
    },
    "schema_id": {
      "const": "star.patch-set",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "status": {
      "$ref": "#/$defs/PatchSetStatus"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "patch_set_id",
    "change_plan_id",
    "change_plan_revision",
    "project_id",
    "base_workspace_snapshot_id",
    "patch_fingerprint",
    "operations",
    "patch_artifact_refs",
    "affected_finding_ids",
    "status",
    "rollback_artifact_refs"
  ],
  "title": "PatchSet",
  "type": "object"
}