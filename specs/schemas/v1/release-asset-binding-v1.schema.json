{
  "$defs": {
    "ReleaseArchitecture": {
      "enum": [
        "x64",
        "arm64"
      ],
      "type": "string"
    },
    "ReleaseAssetSourceV1": {
      "additionalProperties": false,
      "properties": {
        "architecture": {
          "$ref": "#/$defs/ReleaseArchitecture"
        },
        "logical_name": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "relative_path": {
          "type": "string"
        },
        "remote_name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "size": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "logical_name",
        "remote_name",
        "role",
        "architecture",
        "media_type",
        "relative_path",
        "size",
        "sha256"
      ],
      "type": "object"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.release-asset-binding:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Controller-owned local path binding for one immutable release manifest.\n\nThe public `ReleaseManifestV2` remains backend neutral and contains no\nmachine-local paths. This companion document binds those exact bytes to a\nGitHub destination only inside the management store so publication can\nre-read and verify every byte immediately before an external effect.",
  "properties": {
    "artifact_set_digest": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "assets": {
      "items": {
        "$ref": "#/$defs/ReleaseAssetSourceV1"
      },
      "type": "array"
    },
    "binding_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "notes_relative_path": {
      "type": "string"
    },
    "prerelease": {
      "type": "boolean"
    },
    "project_id": {
      "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "release_manifest_id": {
      "pattern": "^rel_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "schema_id": {
      "const": "star.release-asset-binding",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "tag": {
      "type": "string"
    },
    "target_commitish": {
      "type": "string"
    },
    "title": {
      "type": "string"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "release_manifest_id",
    "project_id",
    "artifact_set_digest",
    "assets",
    "repository",
    "tag",
    "target_commitish",
    "title",
    "notes_relative_path",
    "prerelease",
    "binding_fingerprint"
  ],
  "title": "ReleaseAssetBindingV1",
  "type": "object"
}