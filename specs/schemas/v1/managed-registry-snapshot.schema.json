{
  "$defs": {
    "EvidenceCompleteness": {
      "enum": [
        "complete",
        "partial",
        "unverified"
      ],
      "type": "string"
    },
    "ManagedConsumer": {
      "additionalProperties": false,
      "properties": {
        "declaration_id": {
          "type": "string"
        },
        "observed_value": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "source_sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "state": {
          "$ref": "#/$defs/ManagedConsumerState"
        }
      },
      "required": [
        "declaration_id",
        "project_id",
        "path",
        "observed_value",
        "state",
        "source_sha256"
      ],
      "type": "object"
    },
    "ManagedConsumerState": {
      "enum": [
        "bound",
        "alias",
        "unresolved",
        "stale"
      ],
      "type": "string"
    },
    "ManagedDeclaration": {
      "additionalProperties": false,
      "properties": {
        "aliases": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "declaration_id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ManagedDeclarationKind"
        },
        "lifecycle": {
          "$ref": "#/$defs/ManagedLifecycle"
        },
        "namespace": {
          "type": "string"
        },
        "owner_project_id": {
          "type": "string"
        },
        "source_path": {
          "type": "string"
        },
        "source_sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "declaration_id",
        "namespace",
        "kind",
        "value",
        "owner_project_id",
        "source_path",
        "source_sha256",
        "lifecycle"
      ],
      "type": "object"
    },
    "ManagedDeclarationKind": {
      "enum": [
        "error_code",
        "schema_id",
        "config_key"
      ],
      "type": "string"
    },
    "ManagedLifecycle": {
      "enum": [
        "active",
        "deprecated",
        "reserved",
        "removed"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.managed-registry-snapshot:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "completeness": {
      "$ref": "#/$defs/EvidenceCompleteness"
    },
    "consumers": {
      "items": {
        "$ref": "#/$defs/ManagedConsumer"
      },
      "type": "array"
    },
    "content_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "declarations": {
      "items": {
        "$ref": "#/$defs/ManagedDeclaration"
      },
      "type": "array"
    },
    "git_revision": {
      "type": "string"
    },
    "limitations": {
      "default": [],
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "manifest_sha256": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "registry_id": {
      "type": "string"
    },
    "schema_id": {
      "const": "star.managed-registry-snapshot",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "registry_id",
    "git_revision",
    "manifest_sha256",
    "declarations",
    "consumers",
    "completeness",
    "content_fingerprint"
  ],
  "title": "ManagedRegistrySnapshot",
  "type": "object"
}