{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "log",
        "report",
        "diff",
        "screenshot",
        "trace",
        "manifest",
        "input",
        "output",
        "checkpoint",
        "change_set",
        "review_pack"
      ],
      "type": "string"
    },
    "ProducerRef": {
      "additionalProperties": false,
      "properties": {
        "build_id": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "product_version": {
          "type": "string"
        }
      },
      "required": [
        "component",
        "product_version",
        "build_id",
        "platform"
      ],
      "type": "object"
    },
    "RedactionStatus": {
      "enum": [
        "not_needed",
        "redacted",
        "quarantined",
        "unknown"
      ],
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "temporary",
        "run",
        "evidence",
        "hold"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.artifact-ref:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "kind": {
      "$ref": "#/$defs/ArtifactKind"
    },
    "media_type": {
      "type": "string"
    },
    "producer": {
      "$ref": "#/$defs/ProducerRef"
    },
    "project_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "redaction_status": {
      "$ref": "#/$defs/RedactionStatus"
    },
    "relative_path": {
      "type": "string"
    },
    "retention_class": {
      "$ref": "#/$defs/RetentionClass"
    },
    "sha256": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "size_bytes": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "source_artifact_ref": {
      "anyOf": [
        {
          "$ref": "#"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "artifact_id",
    "kind",
    "relative_path",
    "media_type",
    "size_bytes",
    "sha256",
    "created_at",
    "producer",
    "redaction_status",
    "retention_class"
  ],
  "title": "ArtifactRef",
  "type": "object"
}