{
  "$id": "urn:star-control:schema:star.mcp.star_tool_operation_get.input:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "after_sequence": {
      "default": 0,
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    },
    "operation_id": {
      "pattern": "^opn_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "wait_ms": {
      "default": 0,
      "maximum": 30000,
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "operation_id"
  ],
  "type": "object"
}