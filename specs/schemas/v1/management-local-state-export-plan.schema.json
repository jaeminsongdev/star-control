{
  "$defs": {
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.management-local-state-export-plan:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "bundle_id": {
      "pattern": "^lsb_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "destination_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "effective_config_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "expected_store_revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "plan_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "project_id": {
      "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "recovery_plan_id": {
      "pattern": "^rcp_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "schema_id": {
      "const": "star.management-local-state-export-plan",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "source_revision_id": {
      "pattern": "^prv_[a-z2-7]{52}$",
      "type": "string"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "recovery_plan_id",
    "bundle_id",
    "project_id",
    "source_revision_id",
    "effective_config_fingerprint",
    "expected_store_revision",
    "destination_fingerprint",
    "plan_fingerprint"
  ],
  "title": "LocalStateExportPlan",
  "type": "object"
}