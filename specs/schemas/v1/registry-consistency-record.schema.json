{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "log",
        "report",
        "diff",
        "screenshot",
        "trace",
        "manifest",
        "input",
        "output",
        "checkpoint",
        "change_set",
        "review_pack"
      ],
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^art_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "media_type": {
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/ProducerRef"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": [
            "string",
            "null"
          ]
        },
        "redaction_status": {
          "$ref": "#/$defs/RedactionStatus"
        },
        "relative_path": {
          "type": "string"
        },
        "retention_class": {
          "$ref": "#/$defs/RetentionClass"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source_artifact_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "artifact_id",
        "kind",
        "relative_path",
        "media_type",
        "size_bytes",
        "sha256",
        "created_at",
        "producer",
        "redaction_status",
        "retention_class"
      ],
      "type": "object"
    },
    "DocumentRef": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "schema_id": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "schema_id",
        "document_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "EvidenceCompleteness": {
      "enum": [
        "complete",
        "partial",
        "unverified"
      ],
      "type": "string"
    },
    "ManagedDeclarationRef": {
      "additionalProperties": false,
      "properties": {
        "definition_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "item_version": {
          "type": "string"
        },
        "managed_declaration_id": {
          "type": "string"
        }
      },
      "required": [
        "managed_declaration_id",
        "item_version",
        "definition_fingerprint"
      ],
      "type": "object"
    },
    "ProducerRef": {
      "additionalProperties": false,
      "properties": {
        "build_id": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "product_version": {
          "type": "string"
        }
      },
      "required": [
        "component",
        "product_version",
        "build_id",
        "platform"
      ],
      "type": "object"
    },
    "RedactionStatus": {
      "enum": [
        "not_needed",
        "redacted",
        "quarantined",
        "unknown"
      ],
      "type": "string"
    },
    "RegistryConsistencyStatus": {
      "enum": [
        "current",
        "binding_drift",
        "consumer_drift",
        "removed_reference",
        "alias_window_expired",
        "generated_output_stale",
        "docs_schema_drift",
        "stale_registry_index",
        "unverified"
      ],
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "temporary",
        "run",
        "evidence",
        "hold"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.registry-consistency-record:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "completeness": {
      "$ref": "#/$defs/EvidenceCompleteness"
    },
    "declaration_ref": {
      "anyOf": [
        {
          "$ref": "#/$defs/ManagedDeclarationRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "evidence_refs": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "type": "array"
    },
    "expected_value": {
      "type": [
        "string",
        "null"
      ]
    },
    "observed_value": {
      "type": [
        "string",
        "null"
      ]
    },
    "record_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "registry_consistency_record_id": {
      "type": "string"
    },
    "registry_snapshot_ref": {
      "$ref": "#/$defs/DocumentRef"
    },
    "remediation": {
      "type": "string"
    },
    "schema_id": {
      "const": "star.registry-consistency-record",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "status": {
      "$ref": "#/$defs/RegistryConsistencyStatus"
    },
    "subject": {
      "type": "string"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "registry_consistency_record_id",
    "registry_snapshot_ref",
    "status",
    "subject",
    "completeness",
    "remediation",
    "record_fingerprint"
  ],
  "title": "RegistryConsistencyRecord",
  "type": "object"
}