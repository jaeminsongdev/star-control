{
  "$defs": {
    "ChangeEntry": {
      "additionalProperties": false,
      "properties": {
        "after_sha256": {
          "anyOf": [
            {
              "$ref": "#/$defs/Sha256Hash"
            },
            {
              "type": "null"
            }
          ]
        },
        "before_sha256": {
          "anyOf": [
            {
              "$ref": "#/$defs/Sha256Hash"
            },
            {
              "type": "null"
            }
          ]
        },
        "binary": {
          "type": "boolean"
        },
        "change_kind": {
          "$ref": "#/$defs/ObservedChangeKind"
        },
        "entry_id": {
          "type": "string"
        },
        "origin": {
          "$ref": "#/$defs/ChangeOrigin"
        },
        "path": {
          "minLength": 1,
          "pattern": "^[^/\\\\:\\u0000]+(?:/[^/\\\\:\\u0000]+)*$",
          "type": "string"
        },
        "rename_from": {
          "minLength": 1,
          "pattern": "^[^/\\\\:\\u0000]+(?:/[^/\\\\:\\u0000]+)*$",
          "type": [
            "string",
            "null"
          ]
        },
        "scope_relation": {
          "$ref": "#/$defs/ScopeRelation"
        },
        "source_class": {
          "$ref": "#/$defs/SourceClass"
        },
        "staged": {
          "type": "boolean"
        },
        "unstaged": {
          "type": "boolean"
        },
        "untracked": {
          "type": "boolean"
        }
      },
      "required": [
        "entry_id",
        "path",
        "change_kind",
        "staged",
        "unstaged",
        "untracked",
        "binary",
        "source_class",
        "origin",
        "scope_relation"
      ],
      "type": "object"
    },
    "ChangeOrigin": {
      "enum": [
        "preexisting",
        "task_declared",
        "tool_applied",
        "unknown"
      ],
      "type": "string"
    },
    "ChangeSetKind": {
      "enum": [
        "planning_baseline",
        "previous_success_delta",
        "recipe_preview",
        "observed_after_change",
        "merge_result"
      ],
      "type": "string"
    },
    "CollectionState": {
      "enum": [
        "complete",
        "partial",
        "unverified"
      ],
      "type": "string"
    },
    "DocumentRef": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "schema_id": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "schema_id",
        "document_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "ObservedChangeKind": {
      "enum": [
        "add",
        "modify",
        "delete",
        "rename",
        "mode",
        "binary",
        "submodule"
      ],
      "type": "string"
    },
    "PlanningSelector": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/SelectorKind"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "value"
      ],
      "type": "object"
    },
    "ScopeRelation": {
      "enum": [
        "planned",
        "necessary_expansion",
        "unrelated",
        "unknown"
      ],
      "type": "string"
    },
    "SelectorKind": {
      "enum": [
        "path",
        "package",
        "workspace",
        "symbol",
        "contract",
        "config_key",
        "schema",
        "source_class"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "SourceClass": {
      "enum": [
        "source",
        "test",
        "docs",
        "config",
        "schema",
        "migration",
        "vendor",
        "generated",
        "cache",
        "output",
        "unknown"
      ],
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.change-set:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "base_revision_id": {
      "type": "string"
    },
    "captured_at": {
      "format": "date-time",
      "type": "string"
    },
    "change_set_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "change_set_id": {
      "pattern": "^chg_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "change_set_kind": {
      "$ref": "#/$defs/ChangeSetKind"
    },
    "checkout_id": {
      "pattern": "^cko_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "collection_limits": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "collection_state": {
      "$ref": "#/$defs/CollectionState"
    },
    "comparison_scope": {
      "items": {
        "$ref": "#/$defs/PlanningSelector"
      },
      "type": "array"
    },
    "entries": {
      "items": {
        "$ref": "#/$defs/ChangeEntry"
      },
      "type": "array"
    },
    "observed_workspace_snapshot_id": {
      "pattern": "^wsp_[a-z2-7]{52}$",
      "type": "string"
    },
    "project_id": {
      "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "schema_id": {
      "const": "star.change-set",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "scope_revision_ref": {
      "$ref": "#/$defs/DocumentRef"
    },
    "task_spec_ref": {
      "$ref": "#/$defs/DocumentRef"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "change_set_id",
    "task_spec_ref",
    "scope_revision_ref",
    "project_id",
    "checkout_id",
    "change_set_kind",
    "base_revision_id",
    "observed_workspace_snapshot_id",
    "comparison_scope",
    "entries",
    "collection_limits",
    "collection_state",
    "change_set_fingerprint",
    "captured_at"
  ],
  "title": "ChangeSet",
  "type": "object"
}