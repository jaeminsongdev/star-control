{
  "$defs": {
    "ErrorCategory": {
      "enum": [
        "config",
        "contract",
        "state",
        "policy",
        "route",
        "tool",
        "codex",
        "validation",
        "vcs",
        "ipc",
        "release",
        "internal"
      ],
      "type": "string"
    },
    "ErrorEnvelope": {
      "additionalProperties": false,
      "properties": {
        "artifact_refs": {
          "items": true,
          "type": "array"
        },
        "category": {
          "$ref": "#/$defs/ErrorCategory"
        },
        "caused_by": {
          "anyOf": [
            {
              "$ref": "#/$defs/ErrorRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "code": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "context": {
          "additionalProperties": true,
          "type": "object"
        },
        "correlation_id": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "occurred_at": {
          "type": "string"
        },
        "retry_after_ms": {
          "format": "uint64",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "retryable": {
          "type": "boolean"
        },
        "schema_id": {
          "type": "string"
        },
        "schema_version": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "user_action": true
      },
      "required": [
        "schema_id",
        "schema_version",
        "code",
        "category",
        "message",
        "retryable",
        "context",
        "correlation_id",
        "artifact_refs",
        "occurred_at",
        "component"
      ],
      "type": "object"
    },
    "ErrorRef": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "summary"
      ],
      "type": "object"
    },
    "McpResultStatus": {
      "enum": [
        "ok",
        "accepted",
        "question_required",
        "approval_required",
        "blocked",
        "error"
      ],
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.mcp.tool.result:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_refs": {
      "default": [],
      "items": true,
      "type": "array"
    },
    "correlation_id": {
      "type": "string"
    },
    "data": true,
    "diagnostic_refs": {
      "default": [],
      "items": true,
      "type": "array"
    },
    "error": {
      "anyOf": [
        {
          "$ref": "#/$defs/ErrorEnvelope"
        },
        {
          "type": "null"
        }
      ]
    },
    "next_actions": {
      "default": [],
      "items": true,
      "type": "array"
    },
    "operation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "schema_id": {
      "type": "string"
    },
    "schema_version": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "status": {
      "$ref": "#/$defs/McpResultStatus"
    },
    "summary": {
      "type": "string"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "status",
    "summary",
    "correlation_id"
  ],
  "title": "McpToolResult",
  "type": "object"
}