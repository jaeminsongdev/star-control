{
  "$defs": {
    "ActiveStoreGeneration": {
      "additionalProperties": false,
      "properties": {
        "generation": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "header_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "management_store_version": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "relative_locator": {
          "type": "string"
        },
        "scope": {
          "$ref": "#/$defs/StoreScope"
        },
        "store_id": {
          "pattern": "^mst_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        }
      },
      "required": [
        "scope",
        "store_id",
        "generation",
        "management_store_version",
        "relative_locator",
        "header_fingerprint"
      ],
      "type": "object"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "StoreScope": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "global",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "project",
              "type": "string"
            },
            "project_id": {
              "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "project_id"
          ],
          "type": "object"
        }
      ]
    }
  },
  "$id": "urn:star-control:schema:star.management-active-set:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "entries": {
      "items": {
        "$ref": "#/$defs/ActiveStoreGeneration"
      },
      "type": "array"
    },
    "manifest_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "schema_id": {
      "const": "star.management-active-set",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "entries",
    "manifest_fingerprint"
  ],
  "title": "ActiveSetManifest",
  "type": "object"
}