{
  "$defs": {
    "AffectedProject": {
      "additionalProperties": false,
      "properties": {
        "certainty": {
          "$ref": "#/$defs/ImpactCertainty"
        },
        "closure_complete": {
          "type": "boolean"
        },
        "impacted_node_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        }
      },
      "required": [
        "project_id",
        "certainty",
        "closure_complete",
        "impacted_node_count"
      ],
      "type": "object"
    },
    "DocumentRef": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "schema_id": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "schema_id",
        "document_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "ImpactCertainty": {
      "enum": [
        "confirmed",
        "possible"
      ],
      "type": "string"
    },
    "ImpactConfidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ],
      "type": "string"
    },
    "ImpactConfidenceSummary": {
      "additionalProperties": false,
      "properties": {
        "confirmed": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "high": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "low": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "medium": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "possible": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "confirmed",
        "possible",
        "high",
        "medium",
        "low"
      ],
      "type": "object"
    },
    "ImpactEdge": {
      "additionalProperties": false,
      "properties": {
        "certainty": {
          "$ref": "#/$defs/ImpactCertainty"
        },
        "confidence": {
          "$ref": "#/$defs/ImpactConfidence"
        },
        "content_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "distance": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "edge_id": {
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "freshness": {
          "$ref": "#/$defs/IndexFreshnessState"
        },
        "from_entity_key": {
          "type": "string"
        },
        "impact_kind": {
          "$ref": "#/$defs/ImpactKind"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "path_edge_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "relation": {
          "type": "string"
        },
        "resolution": {
          "$ref": "#/$defs/ImpactResolution"
        },
        "tier": {
          "$ref": "#/$defs/IndexTier"
        },
        "to_entity_key": {
          "type": "string"
        }
      },
      "required": [
        "edge_id",
        "project_id",
        "from_entity_key",
        "to_entity_key",
        "relation",
        "impact_kind",
        "distance",
        "certainty",
        "confidence",
        "resolution",
        "tier",
        "freshness",
        "evidence_refs",
        "path_edge_ids",
        "limitations",
        "content_fingerprint"
      ],
      "type": "object"
    },
    "ImpactKind": {
      "enum": [
        "direct",
        "transitive"
      ],
      "type": "string"
    },
    "ImpactProjectInput": {
      "additionalProperties": false,
      "properties": {
        "checkout_id": {
          "pattern": "^cko_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "code_index_snapshot_id": {
          "pattern": "^cix_[a-z2-7]{52}$",
          "type": "string"
        },
        "freshness": {
          "$ref": "#/$defs/IndexFreshnessState"
        },
        "project_catalog_snapshot_id": {
          "pattern": "^pcs_[a-z2-7]{52}$",
          "type": "string"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "project_revision_id": {
          "pattern": "^prv_[a-z2-7]{52}$",
          "type": "string"
        },
        "workspace_snapshot_id": {
          "pattern": "^wsp_[a-z2-7]{52}$",
          "type": "string"
        }
      },
      "required": [
        "project_id",
        "checkout_id",
        "project_catalog_snapshot_id",
        "code_index_snapshot_id",
        "project_revision_id",
        "workspace_snapshot_id",
        "freshness"
      ],
      "type": "object"
    },
    "ImpactResolution": {
      "enum": [
        "resolved",
        "ambiguous",
        "unresolved",
        "external"
      ],
      "type": "string"
    },
    "ImpactSeed": {
      "additionalProperties": false,
      "properties": {
        "entity_key": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "resolution": {
          "$ref": "#/$defs/SeedResolution"
        },
        "seed_id": {
          "type": "string"
        },
        "selector": {
          "$ref": "#/$defs/PlanningSelector"
        }
      },
      "required": [
        "seed_id",
        "project_id",
        "selector",
        "resolution",
        "evidence_refs"
      ],
      "type": "object"
    },
    "ImpactStatus": {
      "enum": [
        "complete",
        "partial",
        "blocked",
        "invalidated"
      ],
      "type": "string"
    },
    "ImpactedNode": {
      "additionalProperties": false,
      "properties": {
        "certainty": {
          "$ref": "#/$defs/ImpactCertainty"
        },
        "confidence": {
          "$ref": "#/$defs/ImpactConfidence"
        },
        "entity_key": {
          "type": "string"
        },
        "impact_kind": {
          "$ref": "#/$defs/ImpactKind"
        },
        "kind": {
          "type": "string"
        },
        "minimum_distance": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        }
      },
      "required": [
        "project_id",
        "entity_key",
        "kind",
        "impact_kind",
        "certainty",
        "confidence",
        "minimum_distance"
      ],
      "type": "object"
    },
    "IndexFreshnessState": {
      "enum": [
        "current",
        "stale_catalog",
        "stale_source",
        "stale_config",
        "stale_adapter",
        "partial",
        "unverified",
        "unavailable"
      ],
      "type": "string"
    },
    "IndexTier": {
      "enum": [
        "text",
        "syntax",
        "semantic"
      ],
      "type": "string"
    },
    "NoResult": {
      "additionalProperties": false,
      "properties": {
        "limitations": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "query_kind": {
          "type": "string"
        },
        "reason": {
          "$ref": "#/$defs/NoResultReason"
        },
        "required_tier": {
          "anyOf": [
            {
              "$ref": "#/$defs/IndexTier"
            },
            {
              "type": "null"
            }
          ]
        },
        "searched_scope": {
          "items": {
            "$ref": "#/$defs/PlanningSelector"
          },
          "type": "array"
        }
      },
      "required": [
        "query_kind",
        "reason",
        "searched_scope",
        "limitations"
      ],
      "type": "object"
    },
    "NoResultReason": {
      "enum": [
        "confirmed_empty",
        "not_indexed",
        "unsupported_language",
        "parse_failed",
        "semantic_unavailable",
        "excluded_by_policy",
        "stale",
        "partial",
        "ambiguous",
        "limit_exceeded",
        "no_seed_mapping",
        "descriptor_not_found",
        "not_applicable"
      ],
      "type": "string"
    },
    "PlanningSelector": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/SelectorKind"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "value"
      ],
      "type": "object"
    },
    "RiskPathFinding": {
      "additionalProperties": false,
      "properties": {
        "certainty": {
          "$ref": "#/$defs/ImpactCertainty"
        },
        "fallback_floor": {
          "$ref": "#/$defs/ValidationScopeLevel"
        },
        "finding_id": {
          "pattern": "^fnd_[a-z2-7]{52}$",
          "type": "string"
        },
        "impact_edge_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "required_check_families": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "risk_id": {
          "type": "string"
        },
        "risk_version": {
          "type": "string"
        },
        "seed_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "severity_floor": {
          "$ref": "#/$defs/RiskSeverityFloor"
        }
      },
      "required": [
        "finding_id",
        "risk_id",
        "risk_version",
        "project_id",
        "seed_ids",
        "impact_edge_ids",
        "certainty",
        "severity_floor",
        "required_check_families",
        "fallback_floor",
        "limitations"
      ],
      "type": "object"
    },
    "RiskSeverityFloor": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "type": "string"
    },
    "SeedResolution": {
      "enum": [
        "resolved",
        "ambiguous",
        "unresolved",
        "excluded",
        "stale"
      ],
      "type": "string"
    },
    "SelectorKind": {
      "enum": [
        "path",
        "package",
        "workspace",
        "symbol",
        "contract",
        "config_key",
        "schema",
        "source_class"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "ValidationScopeLevel": {
      "enum": [
        "package",
        "workspace",
        "project_full"
      ],
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.impact-analysis:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "affected_projects": {
      "items": {
        "$ref": "#/$defs/AffectedProject"
      },
      "type": "array"
    },
    "calculation_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "catalog_snapshot_ref": {
      "$ref": "#/$defs/DocumentRef"
    },
    "change_set_refs": {
      "items": {
        "$ref": "#/$defs/DocumentRef"
      },
      "minItems": 1,
      "type": "array"
    },
    "confidence_summary": {
      "$ref": "#/$defs/ImpactConfidenceSummary"
    },
    "effective_config_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "generated_at": {
      "format": "date-time",
      "type": "string"
    },
    "impact_analysis_id": {
      "pattern": "^imp_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "impact_edges": {
      "items": {
        "$ref": "#/$defs/ImpactEdge"
      },
      "type": "array"
    },
    "impacted_nodes": {
      "items": {
        "$ref": "#/$defs/ImpactedNode"
      },
      "type": "array"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "no_results": {
      "items": {
        "$ref": "#/$defs/NoResult"
      },
      "type": "array"
    },
    "project_inputs": {
      "items": {
        "$ref": "#/$defs/ImpactProjectInput"
      },
      "minItems": 1,
      "type": "array"
    },
    "revision": {
      "format": "uint64",
      "minimum": 1,
      "type": "integer"
    },
    "risk_paths": {
      "items": {
        "$ref": "#/$defs/RiskPathFinding"
      },
      "type": "array"
    },
    "schema_id": {
      "const": "star.impact-analysis",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "scope_revision_ref": {
      "$ref": "#/$defs/DocumentRef"
    },
    "seeds": {
      "items": {
        "$ref": "#/$defs/ImpactSeed"
      },
      "minItems": 1,
      "type": "array"
    },
    "status": {
      "$ref": "#/$defs/ImpactStatus"
    },
    "task_spec_ref": {
      "$ref": "#/$defs/DocumentRef"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "impact_analysis_id",
    "revision",
    "task_spec_ref",
    "scope_revision_ref",
    "project_inputs",
    "change_set_refs",
    "catalog_snapshot_ref",
    "effective_config_fingerprint",
    "seeds",
    "impacted_nodes",
    "impact_edges",
    "risk_paths",
    "affected_projects",
    "no_results",
    "limitations",
    "confidence_summary",
    "calculation_fingerprint",
    "status",
    "generated_at"
  ],
  "title": "ImpactAnalysis",
  "type": "object"
}