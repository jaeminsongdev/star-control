{
  "$defs": {
    "CatalogRef": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "type": "string"
        },
        "format_version": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "item_version": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "catalog_id",
        "format_version",
        "item_version",
        "sha256"
      ],
      "type": "object"
    },
    "DelegatedNamespaceClaim": {
      "additionalProperties": false,
      "properties": {
        "allowed_kinds": {
          "items": {
            "$ref": "#/$defs/ManagedDeclarationKind"
          },
          "type": "array"
        },
        "namespace": {
          "type": "string"
        },
        "owner_project_id": {
          "type": "string"
        }
      },
      "required": [
        "namespace",
        "owner_project_id",
        "allowed_kinds"
      ],
      "type": "object"
    },
    "DocumentRef": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "schema_id": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "schema_id",
        "document_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "ManagedDeclarationKind": {
      "enum": [
        "error_code",
        "diagnostic_id",
        "schema_id",
        "schema_version",
        "config_key",
        "config_default",
        "cli_command",
        "cli_exit_code",
        "event_id",
        "capability_id",
        "permission_id",
        "feature_flag",
        "format_id",
        "resource_id",
        "global_constant"
      ],
      "type": "string"
    },
    "NamespaceClaim": {
      "additionalProperties": false,
      "properties": {
        "allowed_kinds": {
          "items": {
            "$ref": "#/$defs/ManagedDeclarationKind"
          },
          "type": "array"
        },
        "delegated_child_namespaces": {
          "default": [],
          "items": {
            "$ref": "#/$defs/DelegatedNamespaceClaim"
          },
          "type": "array"
        },
        "introduced_in_registry_version": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        },
        "owner_project_id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/NamespaceClaimStatus"
        },
        "transfer_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/DocumentRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "namespace",
        "owner_project_id",
        "allowed_kinds",
        "status",
        "introduced_in_registry_version"
      ],
      "type": "object"
    },
    "NamespaceClaimStatus": {
      "enum": [
        "active",
        "reserved"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.managed-registry-manifest:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "compatibility_policy_ref": {
      "$ref": "#/$defs/CatalogRef"
    },
    "declaration_files": {
      "items": {
        "minLength": 1,
        "pattern": "^[^/\\\\:\\u0000]+(?:/[^/\\\\:\\u0000]+)*$",
        "type": "string"
      },
      "type": "array"
    },
    "extensions": {
      "additionalProperties": true,
      "default": {},
      "type": "object"
    },
    "namespace_claims": {
      "items": {
        "$ref": "#/$defs/NamespaceClaim"
      },
      "type": "array"
    },
    "owner_project_id": {
      "type": "string"
    },
    "registry_id": {
      "type": "string"
    },
    "registry_version": {
      "type": "string"
    },
    "required_check_families": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "schema_id": {
      "const": "star.managed-registry-manifest",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "registry_id",
    "registry_version",
    "owner_project_id",
    "namespace_claims",
    "declaration_files",
    "compatibility_policy_ref",
    "required_check_families"
  ],
  "title": "ManagedRegistryManifest",
  "type": "object"
}