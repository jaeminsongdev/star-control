{
  "$defs": {
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.management-local-state-import-result:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "applied_at": {
      "format": "date-time",
      "type": "string"
    },
    "approved_plan_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "bundle_id": {
      "pattern": "^lsb_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "imported_baselines": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "imported_change_plans": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "imported_dispositions": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "imported_suppressions": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "recovery_plan_id": {
      "pattern": "^rcp_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "result_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "schema_id": {
      "const": "star.management-local-state-import-result",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "recovery_plan_id",
    "bundle_id",
    "applied_at",
    "approved_plan_fingerprint",
    "imported_suppressions",
    "imported_baselines",
    "imported_dispositions",
    "imported_change_plans",
    "result_fingerprint"
  ],
  "title": "LocalStateImportResult",
  "type": "object"
}