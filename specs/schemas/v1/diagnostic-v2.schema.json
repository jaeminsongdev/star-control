{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "log",
        "report",
        "diff",
        "screenshot",
        "trace",
        "manifest",
        "input",
        "output",
        "checkpoint",
        "change_set",
        "review_pack"
      ],
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^art_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "media_type": {
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/ProducerRef"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": [
            "string",
            "null"
          ]
        },
        "redaction_status": {
          "$ref": "#/$defs/RedactionStatus"
        },
        "relative_path": {
          "type": "string"
        },
        "retention_class": {
          "$ref": "#/$defs/RetentionClass"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source_artifact_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "artifact_id",
        "kind",
        "relative_path",
        "media_type",
        "size_bytes",
        "sha256",
        "created_at",
        "producer",
        "redaction_status",
        "retention_class"
      ],
      "type": "object"
    },
    "CatalogRef": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "type": "string"
        },
        "format_version": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "item_version": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "catalog_id",
        "format_version",
        "item_version",
        "sha256"
      ],
      "type": "object"
    },
    "DiagnosticConfidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "type": "string"
    },
    "DiagnosticSeverity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "type": "string"
    },
    "DiagnosticStatus": {
      "enum": [
        "confirmed",
        "suspected",
        "unverified",
        "suppressed",
        "resolved"
      ],
      "type": "string"
    },
    "ProducerRef": {
      "additionalProperties": false,
      "properties": {
        "build_id": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "product_version": {
          "type": "string"
        }
      },
      "required": [
        "component",
        "product_version",
        "build_id",
        "platform"
      ],
      "type": "object"
    },
    "RedactionStatus": {
      "enum": [
        "not_needed",
        "redacted",
        "quarantined",
        "unknown"
      ],
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "temporary",
        "run",
        "evidence",
        "hold"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.diagnostic:v2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "blocking": {
      "type": "boolean"
    },
    "code": {
      "type": "string"
    },
    "confidence": {
      "$ref": "#/$defs/DiagnosticConfidence"
    },
    "diagnostic_id": {
      "type": "string"
    },
    "evidence_refs": {
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "type": "array"
    },
    "fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "first_seen_at": {
      "format": "date-time",
      "type": "string"
    },
    "last_seen_at": {
      "format": "date-time",
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "plan_item_id": {
      "type": "string"
    },
    "project_id": {
      "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "rule_ref": {
      "$ref": "#/$defs/CatalogRef"
    },
    "schema_id": {
      "const": "star.diagnostic",
      "type": "string"
    },
    "schema_version": {
      "const": 2,
      "type": "integer"
    },
    "sequence": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "severity": {
      "$ref": "#/$defs/DiagnosticSeverity"
    },
    "status": {
      "$ref": "#/$defs/DiagnosticStatus"
    },
    "title": {
      "type": "string"
    },
    "validation_run_id": {
      "type": "string"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "diagnostic_id",
    "sequence",
    "code",
    "rule_ref",
    "title",
    "message",
    "severity",
    "confidence",
    "status",
    "blocking",
    "project_id",
    "plan_item_id",
    "validation_run_id",
    "evidence_refs",
    "first_seen_at",
    "last_seen_at",
    "fingerprint"
  ],
  "title": "DiagnosticV2",
  "type": "object"
}