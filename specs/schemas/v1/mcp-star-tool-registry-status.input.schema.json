{
  "$id": "urn:star-control:schema:star.mcp.star_tool_registry_status.input:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "cursor": {
      "anyOf": [
        {
          "maxLength": 1024,
          "pattern": "^[^\\u0000]*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "include_diagnostics": {
      "default": true,
      "type": "boolean"
    },
    "limit": {
      "default": 50,
      "maximum": 200,
      "minimum": 1,
      "type": "integer"
    },
    "package_id": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+){1,7}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "sources": {
      "default": [
        "release",
        "user",
        "project"
      ],
      "items": {
        "enum": [
          "release",
          "user",
          "project"
        ],
        "type": "string"
      },
      "maxItems": 3,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [],
  "type": "object"
}