{
  "$defs": {
    "DevelopmentProfileExtensionsV1": {
      "additionalProperties": false,
      "properties": {
        "migration": {
          "anyOf": [
            {
              "$ref": "#/$defs/MigrationProfileMetadataV1"
            },
            {
              "type": "null"
            }
          ]
        },
        "release": {
          "anyOf": [
            {
              "$ref": "#/$defs/ReleaseProfileMetadataV1"
            },
            {
              "type": "null"
            }
          ]
        },
        "rust_style": {
          "anyOf": [
            {
              "$ref": "#/$defs/RustStyleProfileMetadataV1"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "type": "object"
    },
    "DevelopmentProfileRefV1": {
      "additionalProperties": false,
      "properties": {
        "profile_id": {
          "type": "string"
        },
        "profile_version": {
          "type": "string"
        }
      },
      "required": [
        "profile_id",
        "profile_version"
      ],
      "type": "object"
    },
    "MigrationProfileMetadataV1": {
      "additionalProperties": false,
      "properties": {
        "backup_policy": {
          "type": "string"
        },
        "default_pending_action": {
          "type": "string"
        },
        "destructive_policy": {
          "type": "string"
        },
        "invariant_families": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "rehearsal_policy": {
          "type": "string"
        },
        "restore_policy": {
          "type": "string"
        },
        "resume_policy": {
          "type": "string"
        },
        "strategy_floor": {
          "type": "string"
        },
        "target_kinds": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "target_kinds",
        "invariant_families",
        "strategy_floor",
        "backup_policy",
        "restore_policy",
        "rehearsal_policy",
        "resume_policy",
        "destructive_policy",
        "default_pending_action"
      ],
      "type": "object"
    },
    "ProfileApprovalCheckpointV1": {
      "enum": [
        "network",
        "download",
        "debug_attach",
        "dependency_change",
        "patch_apply",
        "migration_execute",
        "destructive_migration",
        "unknown_field_loss",
        "cross_project_effect",
        "language_cutover",
        "remote_write",
        "release_publish"
      ],
      "type": "string"
    },
    "ProfileBaselinePolicyV1": {
      "enum": [
        "off",
        "report_only",
        "ratchet_new",
        "ratchet_new_and_worsened",
        "clean_only"
      ],
      "type": "string"
    },
    "ProfileEffectClassV1": {
      "enum": [
        "read",
        "plan",
        "validate",
        "local_state_write",
        "workspace_mutation",
        "network_read",
        "remote_write",
        "publish"
      ],
      "type": "string"
    },
    "ProfileGatePhaseV1": {
      "enum": [
        "during_stage",
        "stage_exit",
        "goal_exit",
        "patch_pre_apply",
        "patch_post_apply",
        "merge",
        "migration_pre_execute",
        "migration_post_execute",
        "migration_post_rollback",
        "performance_compare",
        "language_cutover",
        "release",
        "release_preflight",
        "release_build",
        "release_verify",
        "release_package",
        "release_install_lifecycle",
        "release_ready",
        "release_publish_preflight",
        "release_publish_verify"
      ],
      "type": "string"
    },
    "ProfilePermissionFloorV1": {
      "enum": [
        "local_read_only",
        "exact_prompt",
        "exact_durable_approval",
        "deny_external"
      ],
      "type": "string"
    },
    "ProfileReviewFloorV1": {
      "enum": [
        "none",
        "human_semantic",
        "independent_human",
        "block"
      ],
      "type": "string"
    },
    "ProfileReviewPolicyV1": {
      "additionalProperties": false,
      "properties": {
        "cli_only": {
          "$ref": "#/$defs/ProfileReviewFloorV1"
        },
        "codex_managed": {
          "$ref": "#/$defs/ProfileReviewFloorV1"
        }
      },
      "required": [
        "cli_only",
        "codex_managed"
      ],
      "type": "object"
    },
    "ProfileStabilityPolicyV1": {
      "enum": [
        "report_flaky",
        "human_review_flaky",
        "block_required_flaky"
      ],
      "type": "string"
    },
    "ProfileSuppressionPolicyV1": {
      "enum": [
        "exact",
        "bounded_expiring",
        "approved_expiring"
      ],
      "type": "string"
    },
    "ReleaseProfileMetadataV1": {
      "additionalProperties": false,
      "properties": {
        "approval_state_policy_ref": {
          "type": "string"
        },
        "evaluation_contexts": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "evaluation_policy_refs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "package_lifecycle_refs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "release_policy_ref": {
          "type": "string"
        },
        "supply_chain_applicability_ref": {
          "type": "string"
        },
        "target_environment_refs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "validation_layer_refs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "validation_layer_refs",
        "release_policy_ref",
        "target_environment_refs",
        "package_lifecycle_refs",
        "supply_chain_applicability_ref",
        "approval_state_policy_ref",
        "evaluation_policy_refs",
        "evaluation_contexts"
      ],
      "type": "object"
    },
    "RustStyleProfileMetadataV1": {
      "additionalProperties": false,
      "properties": {
        "allowed_live_operations": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "built_in_clippy_fix_allowlist": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "default_policy": {
          "type": "string"
        },
        "network": {
          "type": "string"
        },
        "pipeline_ref": {
          "type": "string"
        },
        "profile_kind": {
          "type": "string"
        },
        "required_gates": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "source_effect": {
          "type": "string"
        },
        "steps": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "supported_policies": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "tool_role_refs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "toolchain_release": {
          "type": "string"
        }
      },
      "required": [
        "profile_kind",
        "pipeline_ref",
        "toolchain_release",
        "default_policy",
        "supported_policies",
        "tool_role_refs",
        "source_effect",
        "network",
        "steps",
        "required_gates",
        "allowed_live_operations",
        "built_in_clippy_fix_allowlist"
      ],
      "type": "object"
    }
  },
  "$id": "urn:star-control:schema:star.development-profile-descriptor:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "allowed_effect_classes": {
      "items": {
        "$ref": "#/$defs/ProfileEffectClassV1"
      },
      "type": "array"
    },
    "always_run_for": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "approval_checkpoints": {
      "items": {
        "$ref": "#/$defs/ProfileApprovalCheckpointV1"
      },
      "type": "array"
    },
    "baseline_policy": {
      "$ref": "#/$defs/ProfileBaselinePolicyV1"
    },
    "claim_policy": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "context_rules": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "corpus_requirements": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "default_stop_state": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "evidence_requirements": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "extensions": {
      "$ref": "#/$defs/DevelopmentProfileExtensionsV1",
      "default": {}
    },
    "gate_phases": {
      "items": {
        "$ref": "#/$defs/ProfileGatePhaseV1"
      },
      "type": "array"
    },
    "optional_check_families": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "parent_profile": {
      "anyOf": [
        {
          "$ref": "#/$defs/DevelopmentProfileRefV1"
        },
        {
          "type": "null"
        }
      ]
    },
    "permission_actions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "permission_floor": {
      "$ref": "#/$defs/ProfilePermissionFloorV1"
    },
    "profile_id": {
      "type": "string"
    },
    "profile_version": {
      "type": "string"
    },
    "required_check_families": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "required_rule_families": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "review_policy": {
      "$ref": "#/$defs/ProfileReviewPolicyV1"
    },
    "route_hints": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "schema_id": {
      "const": "star.development-profile-descriptor",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "stability_policy": {
      "$ref": "#/$defs/ProfileStabilityPolicyV1"
    },
    "stage_template": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "summary": {
      "type": "string"
    },
    "suppression_policy": {
      "$ref": "#/$defs/ProfileSuppressionPolicyV1"
    },
    "triggers": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "profile_id",
    "profile_version",
    "display_name",
    "summary",
    "triggers",
    "stage_template",
    "context_rules",
    "route_hints",
    "permission_actions",
    "gate_phases",
    "required_rule_families",
    "required_check_families",
    "optional_check_families",
    "always_run_for",
    "baseline_policy",
    "suppression_policy",
    "claim_policy",
    "stability_policy",
    "review_policy",
    "evidence_requirements",
    "corpus_requirements",
    "approval_checkpoints",
    "default_stop_state",
    "allowed_effect_classes",
    "permission_floor"
  ],
  "title": "DevelopmentProfileDescriptorV1",
  "type": "object"
}