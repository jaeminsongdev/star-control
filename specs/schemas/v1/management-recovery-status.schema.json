{
  "$defs": {
    "ActiveSetManifest": {
      "additionalProperties": false,
      "properties": {
        "entries": {
          "items": {
            "$ref": "#/$defs/ActiveStoreGeneration"
          },
          "type": "array"
        },
        "manifest_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "schema_id": {
          "type": "string"
        },
        "schema_version": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "schema_id",
        "schema_version",
        "entries",
        "manifest_fingerprint"
      ],
      "type": "object"
    },
    "ActiveStoreGeneration": {
      "additionalProperties": false,
      "properties": {
        "generation": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "header_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "management_store_version": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "relative_locator": {
          "type": "string"
        },
        "scope": {
          "$ref": "#/$defs/StoreScope"
        },
        "store_id": {
          "pattern": "^mst_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        }
      },
      "required": [
        "scope",
        "store_id",
        "generation",
        "management_store_version",
        "relative_locator",
        "header_fingerprint"
      ],
      "type": "object"
    },
    "ControllerRecoveryMode": {
      "enum": [
        "normal",
        "recovery_only"
      ],
      "type": "string"
    },
    "RecoveryInspection": {
      "enum": [
        "missing",
        "healthy",
        "migration_required",
        "future_version",
        "corrupt",
        "active_set_mismatch"
      ],
      "type": "string"
    },
    "RecoveryOperation": {
      "enum": [
        "status",
        "backup_plan",
        "backup_apply",
        "restore_plan",
        "restore_apply",
        "rebuild_plan",
        "rebuild_apply",
        "local_state_export_plan",
        "local_state_export_apply",
        "local_state_import_plan",
        "local_state_import_apply"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "StoreRecoveryStatus": {
      "additionalProperties": false,
      "properties": {
        "diagnostic_code": {
          "type": "string"
        },
        "inspection": {
          "$ref": "#/$defs/RecoveryInspection"
        },
        "relative_locator": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope": {
          "anyOf": [
            {
              "$ref": "#/$defs/StoreScope"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "inspection",
        "diagnostic_code"
      ],
      "type": "object"
    },
    "StoreScope": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "global",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "project",
              "type": "string"
            },
            "project_id": {
              "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "project_id"
          ],
          "type": "object"
        }
      ]
    }
  },
  "$id": "urn:star-control:schema:star.management-recovery-status:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "active_set": {
      "anyOf": [
        {
          "$ref": "#/$defs/ActiveSetManifest"
        },
        {
          "type": "null"
        }
      ]
    },
    "allowed_operations": {
      "items": {
        "$ref": "#/$defs/RecoveryOperation"
      },
      "type": "array"
    },
    "mode": {
      "$ref": "#/$defs/ControllerRecoveryMode"
    },
    "schema_id": {
      "const": "star.management-recovery-status",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "status_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "stores": {
      "items": {
        "$ref": "#/$defs/StoreRecoveryStatus"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "mode",
    "stores",
    "allowed_operations",
    "status_fingerprint"
  ],
  "title": "RecoveryStatus",
  "type": "object"
}