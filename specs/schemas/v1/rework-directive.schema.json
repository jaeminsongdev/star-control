{
  "$defs": {
    "DiagnosticRef": {
      "additionalProperties": false,
      "properties": {
        "diagnostic_id": {
          "type": "string"
        },
        "sequence": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "diagnostic_id",
        "sequence",
        "sha256"
      ],
      "type": "object"
    },
    "GateDecisionRef": {
      "additionalProperties": false,
      "properties": {
        "gate_id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "gate_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.rework-directive:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "blocking_diagnostic_refs": {
      "items": {
        "$ref": "#/$defs/DiagnosticRef"
      },
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "directive_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "expected_actual_differences": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "failed_or_missing_plan_item_ids": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "gate_decision_ref": {
      "$ref": "#/$defs/GateDecisionRef"
    },
    "replan_required": {
      "type": "boolean"
    },
    "required_rechecks": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "rerunnable_same_plan": {
      "type": "boolean"
    },
    "revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "rework_directive_id": {
      "type": "string"
    },
    "safe_remediations": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "schema_id": {
      "const": "star.rework-directive",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "rework_directive_id",
    "revision",
    "gate_decision_ref",
    "blocking_diagnostic_refs",
    "failed_or_missing_plan_item_ids",
    "expected_actual_differences",
    "safe_remediations",
    "required_rechecks",
    "replan_required",
    "rerunnable_same_plan",
    "created_at",
    "directive_fingerprint"
  ],
  "title": "ReworkDirectiveV1",
  "type": "object"
}