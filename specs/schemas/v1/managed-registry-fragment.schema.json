{
  "$defs": {
    "AliasRecord": {
      "additionalProperties": false,
      "properties": {
        "expires_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "expires_in_registry_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "introduced_in_registry_version": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "value",
        "introduced_in_registry_version"
      ],
      "type": "object"
    },
    "BindingSpec": {
      "additionalProperties": false,
      "properties": {
        "binding_id": {
          "type": "string"
        },
        "expected_value": {
          "type": "string"
        },
        "generator_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "$ref": "#/$defs/ManagedBindingKind"
        },
        "path": {
          "minLength": 1,
          "pattern": "^[^/\\\\:\\u0000]+(?:/[^/\\\\:\\u0000]+)*$",
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "symbol_key": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "binding_id",
        "kind",
        "path",
        "expected_value",
        "required"
      ],
      "type": "object"
    },
    "CatalogRef": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "type": "string"
        },
        "format_version": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "item_version": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "catalog_id",
        "format_version",
        "item_version",
        "sha256"
      ],
      "type": "object"
    },
    "ConsumerContract": {
      "additionalProperties": false,
      "properties": {
        "accepted_values": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "consumer_surface_id": {
          "type": "string"
        },
        "migration_window_end": {
          "type": [
            "string",
            "null"
          ]
        },
        "minimum_item_version": {
          "type": "string"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "requirement": {
          "$ref": "#/$defs/ManagedConsumerRequirement"
        }
      },
      "required": [
        "consumer_surface_id",
        "project_id",
        "requirement",
        "minimum_item_version"
      ],
      "type": "object"
    },
    "DocumentRef": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "schema_id": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "schema_id",
        "document_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "ManagedBindingKind": {
      "enum": [
        "definition",
        "reference",
        "schema",
        "docs",
        "generated_output"
      ],
      "type": "string"
    },
    "ManagedConsumerRequirement": {
      "enum": [
        "required",
        "optional",
        "observed_only"
      ],
      "type": "string"
    },
    "ManagedDeclarationKind": {
      "enum": [
        "error_code",
        "diagnostic_id",
        "schema_id",
        "schema_version",
        "config_key",
        "config_default",
        "cli_command",
        "cli_exit_code",
        "event_id",
        "capability_id",
        "permission_id",
        "feature_flag",
        "format_id",
        "resource_id",
        "global_constant"
      ],
      "type": "string"
    },
    "ManagedDeclarationSource": {
      "additionalProperties": false,
      "properties": {
        "aliases": {
          "default": [],
          "items": {
            "$ref": "#/$defs/AliasRecord"
          },
          "type": "array"
        },
        "binding_specs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/BindingSpec"
          },
          "type": "array"
        },
        "consumer_contracts": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ConsumerContract"
          },
          "type": "array"
        },
        "description": {
          "type": "string"
        },
        "item_version": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ManagedDeclarationKind"
        },
        "lifecycle": {
          "$ref": "#/$defs/ManagedLifecycleRecord"
        },
        "managed_declaration_id": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        },
        "owner": {
          "$ref": "#/$defs/ManagedOwnerRef"
        },
        "primary_value": {
          "type": [
            "string",
            "null"
          ]
        },
        "semantic_key": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ManagedLifecycle"
        },
        "uniqueness_scope": {
          "type": "string"
        },
        "value_role": {
          "$ref": "#/$defs/ManagedValueRole"
        },
        "value_type": {
          "type": "string"
        }
      },
      "required": [
        "managed_declaration_id",
        "item_version",
        "namespace",
        "semantic_key",
        "kind",
        "owner",
        "value_type",
        "value_role",
        "description",
        "status",
        "lifecycle",
        "uniqueness_scope"
      ],
      "type": "object"
    },
    "ManagedLifecycle": {
      "enum": [
        "active",
        "deprecated",
        "reserved",
        "removed"
      ],
      "type": "string"
    },
    "ManagedLifecycleRecord": {
      "additionalProperties": false,
      "properties": {
        "deprecated_in_registry_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "introduced_in_registry_version": {
          "type": "string"
        },
        "migration_record_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/DocumentRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "removed_in_registry_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "replacement_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "introduced_in_registry_version"
      ],
      "type": "object"
    },
    "ManagedOwnerRef": {
      "additionalProperties": false,
      "properties": {
        "approval_policy_ref": {
          "$ref": "#/$defs/CatalogRef"
        },
        "contract_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "display_owner": {
          "type": [
            "string",
            "null"
          ]
        },
        "module_key": {
          "type": [
            "string",
            "null"
          ]
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        }
      },
      "required": [
        "project_id",
        "approval_policy_ref"
      ],
      "type": "object"
    },
    "ManagedValueRole": {
      "enum": [
        "stable_identifier",
        "config_default",
        "compile_time_contract"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.managed-registry-fragment:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "declarations": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ManagedDeclarationSource"
      },
      "type": "array"
    },
    "namespace": {
      "type": "string"
    },
    "registry_id": {
      "type": "string"
    },
    "schema_id": {
      "const": "star.managed-registry-fragment",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "source_description": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "registry_id",
    "namespace"
  ],
  "title": "ManagedRegistryFragment",
  "type": "object"
}