{
  "$id": "urn:star-control:schema:star.mcp.star_tool_operation_cancel.input:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "force_after_ms": {
      "anyOf": [
        {
          "maximum": 30000,
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ]
    },
    "operation_id": {
      "pattern": "^opn_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "reason": {
      "anyOf": [
        {
          "maxLength": 512,
          "pattern": "^[^\\u0000]*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "operation_id"
  ],
  "type": "object"
}