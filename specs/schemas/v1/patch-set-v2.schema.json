{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "log",
        "report",
        "diff",
        "screenshot",
        "trace",
        "manifest",
        "input",
        "output",
        "checkpoint",
        "change_set",
        "review_pack"
      ],
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^art_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "media_type": {
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/ProducerRef"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": [
            "string",
            "null"
          ]
        },
        "redaction_status": {
          "$ref": "#/$defs/RedactionStatus"
        },
        "relative_path": {
          "type": "string"
        },
        "retention_class": {
          "$ref": "#/$defs/RetentionClass"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source_artifact_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "artifact_id",
        "kind",
        "relative_path",
        "media_type",
        "size_bytes",
        "sha256",
        "created_at",
        "producer",
        "redaction_status",
        "retention_class"
      ],
      "type": "object"
    },
    "Completeness": {
      "enum": [
        "complete",
        "partial",
        "unverified"
      ],
      "type": "string"
    },
    "DocumentRef": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "schema_id": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "schema_id",
        "document_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "PatchOperation": {
      "additionalProperties": false,
      "properties": {
        "after_mode": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "after_sha256": {
          "anyOf": [
            {
              "$ref": "#/$defs/Sha256Hash"
            },
            {
              "type": "null"
            }
          ]
        },
        "before_mode": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "before_sha256": {
          "anyOf": [
            {
              "$ref": "#/$defs/Sha256Hash"
            },
            {
              "type": "null"
            }
          ]
        },
        "forward_artifact_ref": {
          "$ref": "#/$defs/ArtifactRef"
        },
        "kind": {
          "$ref": "#/$defs/PatchOperationKindV2"
        },
        "operation_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "operation_id": {
          "pattern": "^cop_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "pattern": "^[^/\\\\:\\u0000]+(?:/[^/\\\\:\\u0000]+)*$",
          "type": "string"
        },
        "rename_from": {
          "minLength": 1,
          "pattern": "^[^/\\\\:\\u0000]+(?:/[^/\\\\:\\u0000]+)*$",
          "type": [
            "string",
            "null"
          ]
        },
        "reverse_artifact_ref": {
          "$ref": "#/$defs/ArtifactRef"
        }
      },
      "required": [
        "operation_id",
        "kind",
        "path",
        "forward_artifact_ref",
        "reverse_artifact_ref",
        "operation_fingerprint"
      ],
      "type": "object"
    },
    "PatchOperationKindV2": {
      "enum": [
        "add",
        "modify",
        "delete",
        "rename",
        "generator_input"
      ],
      "type": "string"
    },
    "PatchSetStateV2": {
      "enum": [
        "previewed",
        "replan_required",
        "ready",
        "applying",
        "applied",
        "partially_applied",
        "outcome_unknown",
        "reverted",
        "recovery_blocked"
      ],
      "type": "string"
    },
    "ProducerRef": {
      "additionalProperties": false,
      "properties": {
        "build_id": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "product_version": {
          "type": "string"
        }
      },
      "required": [
        "component",
        "product_version",
        "build_id",
        "platform"
      ],
      "type": "object"
    },
    "RecipeRefV2": {
      "additionalProperties": false,
      "properties": {
        "definition_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "recipe_id": {
          "type": "string"
        },
        "recipe_version": {
          "type": "string"
        }
      },
      "required": [
        "recipe_id",
        "recipe_version",
        "definition_fingerprint"
      ],
      "type": "object"
    },
    "RedactionStatus": {
      "enum": [
        "not_needed",
        "redacted",
        "quarantined",
        "unknown"
      ],
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "temporary",
        "run",
        "evidence",
        "hold"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.patch-set:v2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "base_workspace_snapshot_id": {
      "pattern": "^wsp_[a-z2-7]{52}$",
      "type": "string"
    },
    "change_plan_id": {
      "pattern": "^cpl_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "change_plan_revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "checkout_id": {
      "pattern": "^cko_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "completeness": {
      "$ref": "#/$defs/Completeness"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "expected_operation_set_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "operations": {
      "items": {
        "$ref": "#/$defs/PatchOperation"
      },
      "type": "array"
    },
    "parameter_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "patch_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "patch_set_id": {
      "pattern": "^pat_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "preview_change_set_ref": {
      "$ref": "#/$defs/DocumentRef"
    },
    "preview_impact_analysis_ref": {
      "$ref": "#/$defs/DocumentRef"
    },
    "preview_validation_plan_ref": {
      "$ref": "#/$defs/DocumentRef"
    },
    "project_id": {
      "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "recipe_execution_ref": {
      "$ref": "#/$defs/DocumentRef"
    },
    "recipe_ref": {
      "$ref": "#/$defs/RecipeRefV2"
    },
    "revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "schema_id": {
      "const": "star.patch-set",
      "type": "string"
    },
    "schema_version": {
      "const": 2,
      "type": "integer"
    },
    "state": {
      "$ref": "#/$defs/PatchSetStateV2"
    },
    "target_selector_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "patch_set_id",
    "revision",
    "recipe_ref",
    "recipe_execution_ref",
    "project_id",
    "checkout_id",
    "change_plan_id",
    "change_plan_revision",
    "base_workspace_snapshot_id",
    "target_selector_fingerprint",
    "parameter_fingerprint",
    "operations",
    "preview_change_set_ref",
    "preview_impact_analysis_ref",
    "preview_validation_plan_ref",
    "expected_operation_set_fingerprint",
    "completeness",
    "limitations",
    "state",
    "created_at",
    "patch_fingerprint"
  ],
  "title": "PatchSetV2",
  "type": "object"
}