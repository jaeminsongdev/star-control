{
  "$id": "urn:star-control:schema:star.mcp.star_tool_search.input:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "cursor": {
      "anyOf": [
        {
          "maxLength": 1024,
          "pattern": "^[^\\u0000]*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "limit": {
      "default": 10,
      "maximum": 50,
      "minimum": 1,
      "type": "integer"
    },
    "namespaces": {
      "default": [],
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+){0,7}$",
        "type": "string"
      },
      "maxItems": 16,
      "type": "array",
      "uniqueItems": true
    },
    "query": {
      "maxLength": 256,
      "minLength": 1,
      "pattern": "\\S",
      "type": "string"
    },
    "readiness": {
      "default": [
        "ready"
      ],
      "items": {
        "enum": [
          "ready",
          "unavailable",
          "untrusted",
          "incompatible",
          "degraded"
        ],
        "type": "string"
      },
      "maxItems": 5,
      "type": "array",
      "uniqueItems": true
    },
    "risk_lanes": {
      "default": [
        "read_closed",
        "read_open",
        "write_closed",
        "destructive_closed",
        "write_open",
        "destructive_open"
      ],
      "items": {
        "enum": [
          "read_closed",
          "read_open",
          "write_closed",
          "destructive_closed",
          "write_open",
          "destructive_open"
        ],
        "type": "string"
      },
      "maxItems": 6,
      "type": "array",
      "uniqueItems": true
    },
    "sources": {
      "default": [
        "release",
        "user",
        "project"
      ],
      "items": {
        "enum": [
          "release",
          "user",
          "project"
        ],
        "type": "string"
      },
      "maxItems": 3,
      "type": "array",
      "uniqueItems": true
    },
    "tags": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_-]{0,31}$",
        "type": "string"
      },
      "maxItems": 32,
      "type": "array",
      "uniqueItems": true
    },
    "task_kinds": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_-]{0,31}$",
        "type": "string"
      },
      "maxItems": 16,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "query"
  ],
  "type": "object"
}