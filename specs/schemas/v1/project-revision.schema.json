{
  "$defs": {
    "Completeness": {
      "enum": [
        "complete",
        "partial",
        "unverified"
      ],
      "type": "string"
    },
    "RevisionKind": {
      "enum": [
        "git_commit",
        "filesystem_manifest"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.project-revision:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "captured_at": {
      "format": "date-time",
      "type": "string"
    },
    "commit_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "completeness": {
      "$ref": "#/$defs/Completeness"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "manifest_fingerprint": {
      "anyOf": [
        {
          "$ref": "#/$defs/Sha256Hash"
        },
        {
          "type": "null"
        }
      ]
    },
    "project_id": {
      "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "project_revision_id": {
      "pattern": "^prv_[a-z2-7]{52}$",
      "type": "string"
    },
    "revision_kind": {
      "$ref": "#/$defs/RevisionKind"
    },
    "schema_id": {
      "const": "star.project-revision",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "tree_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "vcs_object_format": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "project_revision_id",
    "project_id",
    "revision_kind",
    "captured_at",
    "completeness",
    "limitations"
  ],
  "title": "ProjectRevision",
  "type": "object"
}