{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "log",
        "report",
        "diff",
        "screenshot",
        "trace",
        "manifest",
        "input",
        "output",
        "checkpoint",
        "change_set",
        "review_pack"
      ],
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^art_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "media_type": {
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/ProducerRef"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": [
            "string",
            "null"
          ]
        },
        "redaction_status": {
          "$ref": "#/$defs/RedactionStatus"
        },
        "relative_path": {
          "type": "string"
        },
        "retention_class": {
          "$ref": "#/$defs/RetentionClass"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source_artifact_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "artifact_id",
        "kind",
        "relative_path",
        "media_type",
        "size_bytes",
        "sha256",
        "created_at",
        "producer",
        "redaction_status",
        "retention_class"
      ],
      "type": "object"
    },
    "ProducerRef": {
      "additionalProperties": false,
      "properties": {
        "build_id": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "product_version": {
          "type": "string"
        }
      },
      "required": [
        "component",
        "product_version",
        "build_id",
        "platform"
      ],
      "type": "object"
    },
    "RedactionStatus": {
      "enum": [
        "not_needed",
        "redacted",
        "quarantined",
        "unknown"
      ],
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "temporary",
        "run",
        "evidence",
        "hold"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "WorktreeDecisionStateV1": {
      "enum": [
        "selected",
        "materialized",
        "retained_for_recovery",
        "discarded",
        "failed"
      ],
      "type": "string"
    },
    "WorktreeStrategyV1": {
      "enum": [
        "current",
        "isolated"
      ],
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.worktree-decision:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "base_workspace_snapshot_id": {
      "pattern": "^wsp_[a-z2-7]{52}$",
      "type": "string"
    },
    "checkout_id": {
      "pattern": "^cko_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "decision_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "isolated_locator_fingerprint": {
      "anyOf": [
        {
          "$ref": "#/$defs/Sha256Hash"
        },
        {
          "type": "null"
        }
      ]
    },
    "materialization_artifact_refs": {
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "type": "array"
    },
    "project_id": {
      "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "reason_codes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "schema_id": {
      "const": "star.worktree-decision",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "state": {
      "$ref": "#/$defs/WorktreeDecisionStateV1"
    },
    "strategy": {
      "$ref": "#/$defs/WorktreeStrategyV1"
    },
    "updated_at": {
      "format": "date-time",
      "type": "string"
    },
    "worktree_decision_id": {
      "type": "string"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "worktree_decision_id",
    "revision",
    "project_id",
    "checkout_id",
    "base_workspace_snapshot_id",
    "strategy",
    "reason_codes",
    "materialization_artifact_refs",
    "state",
    "created_at",
    "updated_at",
    "decision_fingerprint"
  ],
  "title": "WorktreeDecision",
  "type": "object"
}