{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "log",
        "report",
        "diff",
        "screenshot",
        "trace",
        "manifest",
        "input",
        "output",
        "checkpoint",
        "change_set",
        "review_pack"
      ],
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^art_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "media_type": {
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/ProducerRef"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": [
            "string",
            "null"
          ]
        },
        "redaction_status": {
          "$ref": "#/$defs/RedactionStatus"
        },
        "relative_path": {
          "type": "string"
        },
        "retention_class": {
          "$ref": "#/$defs/RetentionClass"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source_artifact_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "artifact_id",
        "kind",
        "relative_path",
        "media_type",
        "size_bytes",
        "sha256",
        "created_at",
        "producer",
        "redaction_status",
        "retention_class"
      ],
      "type": "object"
    },
    "Completeness": {
      "enum": [
        "complete",
        "partial",
        "unverified"
      ],
      "type": "string"
    },
    "DocumentRef": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "schema_id": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "schema_id",
        "document_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "GateDecisionRef": {
      "additionalProperties": false,
      "properties": {
        "gate_id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "gate_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "ProducerRef": {
      "additionalProperties": false,
      "properties": {
        "build_id": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "product_version": {
          "type": "string"
        }
      },
      "required": [
        "component",
        "product_version",
        "build_id",
        "platform"
      ],
      "type": "object"
    },
    "RedactionStatus": {
      "enum": [
        "not_needed",
        "redacted",
        "quarantined",
        "unknown"
      ],
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "temporary",
        "run",
        "evidence",
        "hold"
      ],
      "type": "string"
    },
    "ReviewPackItemV1": {
      "additionalProperties": false,
      "properties": {
        "evidence_refs": {
          "items": {
            "$ref": "#/$defs/DocumentRef"
          },
          "type": "array"
        },
        "item_kind": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "item_kind",
        "status",
        "summary",
        "evidence_refs"
      ],
      "type": "object"
    },
    "ReviewPackSectionV1": {
      "additionalProperties": false,
      "properties": {
        "items": {
          "items": {
            "$ref": "#/$defs/ReviewPackItemV1"
          },
          "type": "array"
        },
        "key": {
          "type": "string"
        }
      },
      "required": [
        "key",
        "items"
      ],
      "type": "object"
    },
    "ReviewQuestionV1": {
      "additionalProperties": false,
      "properties": {
        "impact": {
          "type": "string"
        },
        "options": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "prompt": {
          "type": "string"
        },
        "question_id": {
          "type": "string"
        }
      },
      "required": [
        "question_id",
        "prompt",
        "options",
        "impact"
      ],
      "type": "object"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.review-pack:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "authoritative_gate_decision_ref": {
      "$ref": "#/$defs/GateDecisionRef"
    },
    "completeness": {
      "$ref": "#/$defs/Completeness"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "evidence_bundle_ref": {
      "$ref": "#/$defs/DocumentRef"
    },
    "missing_reasons": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "questions": {
      "items": {
        "$ref": "#/$defs/ReviewQuestionV1"
      },
      "type": "array"
    },
    "rendered_artifact_refs": {
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "type": "array"
    },
    "required_action_refs": {
      "items": {
        "$ref": "#/$defs/DocumentRef"
      },
      "type": "array"
    },
    "review_pack_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "review_pack_id": {
      "type": "string"
    },
    "revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "schema_id": {
      "const": "star.review-pack",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "section_order": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "sections": {
      "items": {
        "$ref": "#/$defs/ReviewPackSectionV1"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "review_pack_id",
    "revision",
    "evidence_bundle_ref",
    "authoritative_gate_decision_ref",
    "section_order",
    "sections",
    "questions",
    "required_action_refs",
    "rendered_artifact_refs",
    "completeness",
    "missing_reasons",
    "created_at",
    "review_pack_fingerprint"
  ],
  "title": "ReviewPackV1",
  "type": "object"
}