{
  "$defs": {
    "ActorRef": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "type": "string"
        },
        "actor_type": {
          "$ref": "#/$defs/ActorType"
        },
        "auth_source": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        }
      },
      "required": [
        "actor_type",
        "actor_id",
        "display_name",
        "auth_source"
      ],
      "type": "object"
    },
    "ActorType": {
      "enum": [
        "user",
        "codex",
        "system",
        "controller",
        "mcp",
        "tool"
      ],
      "type": "string"
    },
    "ArtifactKind": {
      "enum": [
        "log",
        "report",
        "diff",
        "screenshot",
        "trace",
        "manifest",
        "input",
        "output",
        "checkpoint",
        "change_set",
        "review_pack"
      ],
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^art_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "media_type": {
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/ProducerRef"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": [
            "string",
            "null"
          ]
        },
        "redaction_status": {
          "$ref": "#/$defs/RedactionStatus"
        },
        "relative_path": {
          "type": "string"
        },
        "retention_class": {
          "$ref": "#/$defs/RetentionClass"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source_artifact_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "artifact_id",
        "kind",
        "relative_path",
        "media_type",
        "size_bytes",
        "sha256",
        "created_at",
        "producer",
        "redaction_status",
        "retention_class"
      ],
      "type": "object"
    },
    "BaselineRelationV2": {
      "enum": [
        "new",
        "existing_unchanged",
        "worsened",
        "improved",
        "not_observed",
        "incompatible",
        "unbaselined"
      ],
      "type": "string"
    },
    "CatalogRef": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "type": "string"
        },
        "format_version": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "item_version": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "catalog_id",
        "format_version",
        "item_version",
        "sha256"
      ],
      "type": "object"
    },
    "CheckRequirementV2": {
      "enum": [
        "required",
        "optional"
      ],
      "type": "string"
    },
    "ClaimEvaluationStatusV2": {
      "enum": [
        "verified",
        "contradicted",
        "unverified",
        "stale",
        "not_applicable"
      ],
      "type": "string"
    },
    "ClaimEvaluationV2": {
      "additionalProperties": false,
      "properties": {
        "actual_evidence_refs": {
          "items": {
            "$ref": "#/$defs/ClaimEvidenceRefV2"
          },
          "type": "array"
        },
        "claim_ref": {
          "$ref": "#/$defs/CompletionClaimRefV2"
        },
        "current_subject_binding": {
          "$ref": "#/$defs/EvidenceSubjectBinding"
        },
        "diagnostic_refs": {
          "items": {
            "$ref": "#/$defs/DiagnosticRef"
          },
          "type": "array"
        },
        "evaluation_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "gate_effect": {
          "$ref": "#/$defs/ClaimGateEffectV2"
        },
        "reason_codes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/ClaimEvaluationStatusV2"
        }
      },
      "required": [
        "claim_ref",
        "current_subject_binding",
        "actual_evidence_refs",
        "status",
        "diagnostic_refs",
        "gate_effect",
        "reason_codes",
        "evaluation_fingerprint"
      ],
      "type": "object"
    },
    "ClaimEvidenceRefV2": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "document_ref": {
              "$ref": "#/$defs/DocumentRef"
            },
            "kind": {
              "const": "document",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "document_ref"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "validation_run",
              "type": "string"
            },
            "validation_run_ref": {
              "$ref": "#/$defs/ValidationRunRef"
            }
          },
          "required": [
            "kind",
            "validation_run_ref"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "artifact_ref": {
              "$ref": "#/$defs/ArtifactRef"
            },
            "kind": {
              "const": "artifact",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "artifact_ref"
          ],
          "type": "object"
        }
      ]
    },
    "ClaimGateEffectV2": {
      "enum": [
        "none",
        "human_review",
        "block"
      ],
      "type": "string"
    },
    "CompletionClaimRefV2": {
      "additionalProperties": false,
      "properties": {
        "claim_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "claim_id": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        }
      },
      "required": [
        "claim_id",
        "required",
        "claim_fingerprint"
      ],
      "type": "object"
    },
    "DecisionDocumentRefV2": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "type": "string"
        },
        "fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "document_id",
        "revision",
        "fingerprint"
      ],
      "type": "object"
    },
    "DiagnosticEvaluationSubjectV2": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "diagnostic_ref": {
              "$ref": "#/$defs/DiagnosticRef"
            },
            "kind": {
              "const": "current_diagnostic",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "diagnostic_ref"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "baseline_id": {
              "pattern": "^bas_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            },
            "entry_fingerprint": {
              "$ref": "#/$defs/Sha256Hash"
            },
            "kind": {
              "const": "baseline_entry",
              "type": "string"
            },
            "revision": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "kind",
            "baseline_id",
            "revision",
            "entry_fingerprint"
          ],
          "type": "object"
        }
      ]
    },
    "DiagnosticEvaluationV2": {
      "additionalProperties": false,
      "properties": {
        "baseline_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/DecisionDocumentRefV2"
            },
            {
              "type": "null"
            }
          ]
        },
        "baseline_relation": {
          "$ref": "#/$defs/BaselineRelationV2"
        },
        "disposition_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/DecisionDocumentRefV2"
            },
            {
              "type": "null"
            }
          ]
        },
        "evaluation_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "evaluation_subject": {
          "$ref": "#/$defs/DiagnosticEvaluationSubjectV2"
        },
        "gate_effect": {
          "$ref": "#/$defs/DiagnosticGateEffectV2"
        },
        "reason_codes": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "subject_binding_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "suppression_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/DecisionDocumentRefV2"
            },
            {
              "type": "null"
            }
          ]
        },
        "suppression_state": {
          "$ref": "#/$defs/SuppressionStateV2"
        }
      },
      "required": [
        "evaluation_subject",
        "subject_binding_fingerprint",
        "baseline_relation",
        "suppression_state",
        "gate_effect",
        "reason_codes",
        "evaluation_fingerprint"
      ],
      "type": "object"
    },
    "DiagnosticGateEffectV2": {
      "enum": [
        "none",
        "remaining_risk",
        "requires_review",
        "blocks"
      ],
      "type": "string"
    },
    "DiagnosticRef": {
      "additionalProperties": false,
      "properties": {
        "diagnostic_id": {
          "type": "string"
        },
        "sequence": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "diagnostic_id",
        "sequence",
        "sha256"
      ],
      "type": "object"
    },
    "DiagnosticSeverity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "type": "string"
    },
    "DocumentRef": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "schema_id": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "schema_id",
        "document_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "EvidenceFreshnessV2": {
      "enum": [
        "current",
        "stale_source",
        "stale_plan",
        "stale_config",
        "stale_catalog",
        "stale_tool",
        "stale_environment",
        "unverified"
      ],
      "type": "string"
    },
    "EvidenceSubjectBinding": {
      "additionalProperties": false,
      "properties": {
        "binding_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "catalog_snapshot_ref": {
          "$ref": "#/$defs/DocumentRef"
        },
        "change_plan_refs": {
          "items": {
            "$ref": "#/$defs/DocumentRef"
          },
          "type": "array"
        },
        "change_set_refs": {
          "items": {
            "$ref": "#/$defs/DocumentRef"
          },
          "type": "array"
        },
        "check_descriptor_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/DocumentRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "checkout_id": {
          "pattern": "^cko_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "effective_config_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "execution_environment_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "freshness": {
          "$ref": "#/$defs/EvidenceFreshnessV2"
        },
        "gate_phase": {
          "$ref": "#/$defs/GatePhaseV2"
        },
        "gate_policy_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "impact_analysis_ref": {
          "$ref": "#/$defs/DocumentRef"
        },
        "invocation_fingerprint": {
          "anyOf": [
            {
              "$ref": "#/$defs/Sha256Hash"
            },
            {
              "type": "null"
            }
          ]
        },
        "normalizer_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "observed_tool_fingerprint": {
          "anyOf": [
            {
              "$ref": "#/$defs/Sha256Hash"
            },
            {
              "type": "null"
            }
          ]
        },
        "patch_set_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/DocumentRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "probed_at": {
          "format": "date-time",
          "type": "string"
        },
        "profile_resolution_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "project_revision_id": {
          "pattern": "^prv_[a-z2-7]{52}$",
          "type": "string"
        },
        "rule_refs": {
          "items": {
            "$ref": "#/$defs/CatalogRef"
          },
          "type": "array"
        },
        "scope_revision_ref": {
          "$ref": "#/$defs/DocumentRef"
        },
        "stale_reasons": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "task_spec_ref": {
          "$ref": "#/$defs/DocumentRef"
        },
        "tool_descriptor_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/CatalogRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "tool_registry_snapshot_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/DocumentRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "validation_plan_ref": {
          "$ref": "#/$defs/DocumentRef"
        },
        "validator_registry_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "workspace_content_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "workspace_snapshot_id": {
          "pattern": "^wsp_[a-z2-7]{52}$",
          "type": "string"
        }
      },
      "required": [
        "project_id",
        "checkout_id",
        "project_revision_id",
        "workspace_snapshot_id",
        "workspace_content_fingerprint",
        "task_spec_ref",
        "scope_revision_ref",
        "impact_analysis_ref",
        "change_set_refs",
        "change_plan_refs",
        "validation_plan_ref",
        "gate_phase",
        "profile_resolution_fingerprint",
        "effective_config_fingerprint",
        "gate_policy_fingerprint",
        "catalog_snapshot_ref",
        "validator_registry_fingerprint",
        "rule_refs",
        "execution_environment_fingerprint",
        "normalizer_fingerprint",
        "freshness",
        "stale_reasons",
        "binding_fingerprint",
        "probed_at"
      ],
      "type": "object"
    },
    "GateDecisionKind": {
      "enum": [
        "auto_pass",
        "human_review",
        "block"
      ],
      "type": "string"
    },
    "GatePhaseV2": {
      "enum": [
        "during_stage",
        "goal_exit",
        "patch_pre_apply",
        "patch_post_apply"
      ],
      "type": "string"
    },
    "GateScope": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "goal_id": {
              "pattern": "^gol_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            },
            "kind": {
              "const": "goal",
              "type": "string"
            },
            "revision": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "run_id": {
              "pattern": "^run_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "goal_id",
            "run_id",
            "revision"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "goal_id": {
              "pattern": "^gol_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            },
            "kind": {
              "const": "stage",
              "type": "string"
            },
            "revision": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "run_id": {
              "pattern": "^run_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            },
            "stage_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "goal_id",
            "run_id",
            "stage_id",
            "revision"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "merge",
              "type": "string"
            },
            "project_id": {
              "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            },
            "revision": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "kind",
            "project_id",
            "revision"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "release",
              "type": "string"
            },
            "project_id": {
              "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            },
            "revision": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "kind",
            "project_id",
            "revision"
          ],
          "type": "object"
        }
      ]
    },
    "ProducerRef": {
      "additionalProperties": false,
      "properties": {
        "build_id": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "product_version": {
          "type": "string"
        }
      },
      "required": [
        "component",
        "product_version",
        "build_id",
        "platform"
      ],
      "type": "object"
    },
    "RedactionStatus": {
      "enum": [
        "not_needed",
        "redacted",
        "quarantined",
        "unknown"
      ],
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "temporary",
        "run",
        "evidence",
        "hold"
      ],
      "type": "string"
    },
    "RiskRef": {
      "additionalProperties": false,
      "properties": {
        "evidence_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactRef"
          },
          "type": "array"
        },
        "risk_id": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/DiagnosticSeverity"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "risk_id",
        "title",
        "severity"
      ],
      "type": "object"
    },
    "RunGateEffectV2": {
      "enum": [
        "none",
        "human_review",
        "block"
      ],
      "type": "string"
    },
    "RunSatisfactionStateV2": {
      "enum": [
        "clean_pass",
        "ratchet_satisfied",
        "unsatisfied",
        "waived_for_review"
      ],
      "type": "string"
    },
    "RunSatisfactionV2": {
      "additionalProperties": false,
      "properties": {
        "content_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "diagnostic_evaluation_fingerprints": {
          "items": {
            "$ref": "#/$defs/Sha256Hash"
          },
          "type": "array"
        },
        "gate_effect": {
          "$ref": "#/$defs/RunGateEffectV2"
        },
        "plan_item_id": {
          "type": "string"
        },
        "policy_reason": {
          "type": "string"
        },
        "raw_outcomes": {
          "items": {
            "$ref": "#/$defs/ValidationOutcome"
          },
          "type": "array"
        },
        "reason_code": {
          "type": "string"
        },
        "requirement": {
          "$ref": "#/$defs/CheckRequirementV2"
        },
        "satisfaction": {
          "$ref": "#/$defs/RunSatisfactionStateV2"
        },
        "validation_run_refs": {
          "items": {
            "$ref": "#/$defs/ValidationRunRef"
          },
          "type": "array"
        }
      },
      "required": [
        "plan_item_id",
        "requirement",
        "validation_run_refs",
        "raw_outcomes",
        "satisfaction",
        "gate_effect",
        "reason_code",
        "diagnostic_evaluation_fingerprints",
        "policy_reason",
        "content_fingerprint"
      ],
      "type": "object"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "SuppressionStateV2": {
      "enum": [
        "none",
        "active",
        "expired",
        "stale",
        "revoked",
        "invalid"
      ],
      "type": "string"
    },
    "ValidationOutcome": {
      "enum": [
        "pass",
        "fail",
        "not_run",
        "error",
        "cancelled"
      ],
      "type": "string"
    },
    "ValidationRunRef": {
      "additionalProperties": false,
      "properties": {
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "validation_run_id": {
          "type": "string"
        }
      },
      "required": [
        "validation_run_id",
        "revision",
        "sha256"
      ],
      "type": "object"
