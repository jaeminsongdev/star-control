{
  "$defs": {
    "ActorRef": {
      "additionalProperties": false,
      "properties": {
        "actor_id": {
          "type": "string"
        },
        "actor_type": {
          "$ref": "#/$defs/ActorType"
        },
        "auth_source": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        }
      },
      "required": [
        "actor_type",
        "actor_id",
        "display_name",
        "auth_source"
      ],
      "type": "object"
    },
    "ActorType": {
      "enum": [
        "user",
        "codex",
        "system",
        "controller",
        "mcp",
        "tool"
      ],
      "type": "string"
    },
    "ArtifactKind": {
      "enum": [
        "log",
        "report",
        "diff",
        "screenshot",
        "trace",
        "manifest",
        "input",
        "output",
        "checkpoint",
        "change_set",
        "review_pack"
      ],
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^art_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "media_type": {
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/ProducerRef"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": [
            "string",
            "null"
          ]
        },
        "redaction_status": {
          "$ref": "#/$defs/RedactionStatus"
        },
        "relative_path": {
          "type": "string"
        },
        "retention_class": {
          "$ref": "#/$defs/RetentionClass"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source_artifact_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "artifact_id",
        "kind",
        "relative_path",
        "media_type",
        "size_bytes",
        "sha256",
        "created_at",
        "producer",
        "redaction_status",
        "retention_class"
      ],
      "type": "object"
    },
    "DiagnosticRef": {
      "additionalProperties": false,
      "properties": {
        "diagnostic_id": {
          "type": "string"
        },
        "sequence": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "diagnostic_id",
        "sequence",
        "sha256"
      ],
      "type": "object"
    },
    "DiagnosticSeverity": {
      "enum": [
        "info",
        "warning",
        "error",
        "critical"
      ],
      "type": "string"
    },
    "DocumentRef": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "schema_id": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "schema_id",
        "document_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "GateDecisionKind": {
      "enum": [
        "auto_pass",
        "human_review",
        "block"
      ],
      "type": "string"
    },
    "GateScope": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "goal_id": {
              "pattern": "^gol_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            },
            "kind": {
              "const": "goal",
              "type": "string"
            },
            "revision": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "run_id": {
              "pattern": "^run_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "goal_id",
            "run_id",
            "revision"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "goal_id": {
              "pattern": "^gol_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            },
            "kind": {
              "const": "stage",
              "type": "string"
            },
            "revision": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            },
            "run_id": {
              "pattern": "^run_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            },
            "stage_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "goal_id",
            "run_id",
            "stage_id",
            "revision"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "merge",
              "type": "string"
            },
            "project_id": {
              "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            },
            "revision": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "kind",
            "project_id",
            "revision"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "release",
              "type": "string"
            },
            "project_id": {
              "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
              "type": "string"
            },
            "revision": {
              "format": "uint64",
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "kind",
            "project_id",
            "revision"
          ],
          "type": "object"
        }
      ]
    },
    "ProducerRef": {
      "additionalProperties": false,
      "properties": {
        "build_id": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "product_version": {
          "type": "string"
        }
      },
      "required": [
        "component",
        "product_version",
        "build_id",
        "platform"
      ],
      "type": "object"
    },
    "RedactionStatus": {
      "enum": [
        "not_needed",
        "redacted",
        "quarantined",
        "unknown"
      ],
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "temporary",
        "run",
        "evidence",
        "hold"
      ],
      "type": "string"
    },
    "RiskRef": {
      "additionalProperties": false,
      "properties": {
        "evidence_refs": {
          "default": [],
          "items": {
            "$ref": "#/$defs/ArtifactRef"
          },
          "type": "array"
        },
        "risk_id": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/DiagnosticSeverity"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "risk_id",
        "title",
        "severity"
      ],
      "type": "object"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "ValidationRunRef": {
      "additionalProperties": false,
      "properties": {
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "validation_run_id": {
          "type": "string"
        }
      },
      "required": [
        "validation_run_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    }
  },
  "$id": "urn:star-control:schema:star.gate-decision:v2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "blocking_diagnostic_refs": {
      "items": {
        "$ref": "#/$defs/DiagnosticRef"
      },
      "type": "array"
    },
    "decided_at": {
      "format": "date-time",
      "type": "string"
    },
    "decided_by": {
      "$ref": "#/$defs/ActorRef"
    },
    "decision": {
      "$ref": "#/$defs/GateDecisionKind"
    },
    "decision_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "gate_id": {
      "type": "string"
    },
    "policy_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "reason_codes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "remaining_risks": {
      "items": {
        "$ref": "#/$defs/RiskRef"
      },
      "type": "array"
    },
    "required_run_refs": {
      "items": {
        "$ref": "#/$defs/ValidationRunRef"
      },
      "type": "array"
    },
    "revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "satisfied_run_refs": {
      "items": {
        "$ref": "#/$defs/ValidationRunRef"
      },
      "type": "array"
    },
    "schema_id": {
      "const": "star.gate-decision",
      "type": "string"
    },
    "schema_version": {
      "const": 2,
      "type": "integer"
    },
    "scope": {
      "$ref": "#/$defs/GateScope"
    },
    "validation_plan_ref": {
      "$ref": "#/$defs/DocumentRef"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "gate_id",
    "revision",
    "validation_plan_ref",
    "scope",
    "decision",
    "required_run_refs",
    "satisfied_run_refs",
    "blocking_diagnostic_refs",
    "reason_codes",
    "remaining_risks",
    "policy_fingerprint",
    "decided_by",
    "decided_at",
    "decision_fingerprint"
  ],
  "title": "GateDecisionV2",
  "type": "object"
}