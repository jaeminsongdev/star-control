{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "log",
        "report",
        "diff",
        "screenshot",
        "trace",
        "manifest",
        "input",
        "output",
        "checkpoint",
        "change_set",
        "review_pack"
      ],
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "pattern": "^art_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "media_type": {
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/ProducerRef"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": [
            "string",
            "null"
          ]
        },
        "redaction_status": {
          "$ref": "#/$defs/RedactionStatus"
        },
        "relative_path": {
          "type": "string"
        },
        "retention_class": {
          "$ref": "#/$defs/RetentionClass"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "size_bytes": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source_artifact_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "artifact_id",
        "kind",
        "relative_path",
        "media_type",
        "size_bytes",
        "sha256",
        "created_at",
        "producer",
        "redaction_status",
        "retention_class"
      ],
      "type": "object"
    },
    "CatalogRef": {
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "type": "string"
        },
        "format_version": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "item_version": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "catalog_id",
        "format_version",
        "item_version",
        "sha256"
      ],
      "type": "object"
    },
    "Completeness": {
      "enum": [
        "complete",
        "partial",
        "unverified"
      ],
      "type": "string"
    },
    "DocumentRef": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "schema_id": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "schema_id",
        "document_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "EnvironmentValueRef": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "source": {
              "const": "literal",
              "type": "string"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "source",
            "value"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "secret_ref": {
              "$ref": "#/$defs/DocumentRef"
            },
            "source": {
              "const": "secret",
              "type": "string"
            }
          },
          "required": [
            "source",
            "secret_ref"
          ],
          "type": "object"
        }
      ]
    },
    "EvidenceFreshnessV2": {
      "enum": [
        "current",
        "stale_source",
        "stale_plan",
        "stale_config",
        "stale_catalog",
        "stale_tool",
        "stale_environment",
        "unverified"
      ],
      "type": "string"
    },
    "EvidenceSubjectBinding": {
      "additionalProperties": false,
      "properties": {
        "binding_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "catalog_snapshot_ref": {
          "$ref": "#/$defs/DocumentRef"
        },
        "change_plan_refs": {
          "items": {
            "$ref": "#/$defs/DocumentRef"
          },
          "type": "array"
        },
        "change_set_refs": {
          "items": {
            "$ref": "#/$defs/DocumentRef"
          },
          "type": "array"
        },
        "check_descriptor_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/DocumentRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "checkout_id": {
          "pattern": "^cko_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "effective_config_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "execution_environment_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "freshness": {
          "$ref": "#/$defs/EvidenceFreshnessV2"
        },
        "gate_phase": {
          "$ref": "#/$defs/GatePhaseV2"
        },
        "gate_policy_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "impact_analysis_ref": {
          "$ref": "#/$defs/DocumentRef"
        },
        "invocation_fingerprint": {
          "anyOf": [
            {
              "$ref": "#/$defs/Sha256Hash"
            },
            {
              "type": "null"
            }
          ]
        },
        "normalizer_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "observed_tool_fingerprint": {
          "anyOf": [
            {
              "$ref": "#/$defs/Sha256Hash"
            },
            {
              "type": "null"
            }
          ]
        },
        "patch_set_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/DocumentRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "probed_at": {
          "format": "date-time",
          "type": "string"
        },
        "profile_resolution_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "project_id": {
          "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
          "type": "string"
        },
        "project_revision_id": {
          "pattern": "^prv_[a-z2-7]{52}$",
          "type": "string"
        },
        "rule_refs": {
          "items": {
            "$ref": "#/$defs/CatalogRef"
          },
          "type": "array"
        },
        "scope_revision_ref": {
          "$ref": "#/$defs/DocumentRef"
        },
        "stale_reasons": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "task_spec_ref": {
          "$ref": "#/$defs/DocumentRef"
        },
        "tool_descriptor_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/CatalogRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "tool_registry_snapshot_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/DocumentRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "validation_plan_ref": {
          "$ref": "#/$defs/DocumentRef"
        },
        "validator_registry_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "workspace_content_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "workspace_snapshot_id": {
          "pattern": "^wsp_[a-z2-7]{52}$",
          "type": "string"
        }
      },
      "required": [
        "project_id",
        "checkout_id",
        "project_revision_id",
        "workspace_snapshot_id",
        "workspace_content_fingerprint",
        "task_spec_ref",
        "scope_revision_ref",
        "impact_analysis_ref",
        "change_set_refs",
        "change_plan_refs",
        "validation_plan_ref",
        "gate_phase",
        "profile_resolution_fingerprint",
        "effective_config_fingerprint",
        "gate_policy_fingerprint",
        "catalog_snapshot_ref",
        "validator_registry_fingerprint",
        "rule_refs",
        "execution_environment_fingerprint",
        "normalizer_fingerprint",
        "freshness",
        "stale_reasons",
        "binding_fingerprint",
        "probed_at"
      ],
      "type": "object"
    },
    "GatePhaseV2": {
      "enum": [
        "during_stage",
        "goal_exit",
        "patch_pre_apply",
        "patch_post_apply"
      ],
      "type": "string"
    },
    "InvocationWorkingDirectoryV2": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "project_root",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "project_path",
              "type": "string"
            },
            "path": {
              "minLength": 1,
              "pattern": "^[^/\\\\:\\u0000]+(?:/[^/\\\\:\\u0000]+)*$",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "path"
          ],
          "type": "object"
        }
      ]
    },
    "NotRunReasonV2": {
      "enum": [
        "dependency_unsatisfied",
        "permission_blocked",
        "tool_unavailable",
        "preflight_invalidated",
        "cancelled_before_start",
        "launch_error"
      ],
      "type": "string"
    },
    "ObservedTool": {
      "additionalProperties": false,
      "properties": {
        "executable_path": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "executable_path",
        "version",
        "sha256"
      ],
      "type": "object"
    },
    "OutputLimits": {
      "additionalProperties": false,
      "properties": {
        "artifact_bytes": {
          "format": "uint64",
          "minimum": 1,
          "type": "integer"
        },
        "stderr_bytes": {
          "format": "uint64",
          "minimum": 1,
          "type": "integer"
        },
        "stdout_bytes": {
          "format": "uint64",
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "stdout_bytes",
        "stderr_bytes",
        "artifact_bytes"
      ],
      "type": "object"
    },
    "ProcessStartStateV2": {
      "enum": [
        "not_started",
        "started",
        "unknown"
      ],
      "type": "string"
    },
    "ProducerRef": {
      "additionalProperties": false,
      "properties": {
        "build_id": {
          "type": "string"
        },
        "component": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "product_version": {
          "type": "string"
        }
      },
      "required": [
        "component",
        "product_version",
        "build_id",
        "platform"
      ],
      "type": "object"
    },
    "RedactionStatus": {
      "enum": [
        "not_needed",
        "redacted",
        "quarantined",
        "unknown"
      ],
      "type": "string"
    },
    "RetentionClass": {
      "enum": [
        "temporary",
        "run",
        "evidence",
        "hold"
      ],
      "type": "string"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "TaskInvocationV2": {
      "additionalProperties": false,
      "properties": {
        "args": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "cwd": {
          "$ref": "#/$defs/InvocationWorkingDirectoryV2"
        },
        "env_refs": {
          "additionalProperties": {
            "$ref": "#/$defs/EnvironmentValueRef"
          },
          "type": "object"
        },
        "executable": {
          "type": "string"
        },
        "executable_binding_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "expected_exit_codes": {
          "items": {
            "format": "int32",
            "type": "integer"
          },
          "type": "array",
          "uniqueItems": true
        },
        "idempotency_key": {
          "type": "string"
        },
        "input_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "invocation_id": {
          "type": "string"
        },
        "output_limits": {
          "$ref": "#/$defs/OutputLimits"
        },
        "permission_action": {
          "type": "string"
        },
        "schema_id": {
          "type": "string"
        },
        "schema_version": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "stdin_ref": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactRef"
            },
            {
              "type": "null"
            }
          ]
        },
        "timeout_ms": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "tool_ref": {
          "$ref": "#/$defs/CatalogRef"
        }
      },
      "required": [
        "schema_id",
        "schema_version",
        "invocation_id",
        "tool_ref",
        "executable",
        "executable_binding_fingerprint",
        "args",
        "cwd",
        "env_refs",
        "timeout_ms",
        "permission_action",
        "idempotency_key",
        "expected_exit_codes",
        "output_limits",
        "input_fingerprint"
      ],
      "type": "object"
    },
    "TerminationReason": {
      "enum": [
        "exited",
        "timeout",
        "cancelled",
        "launch_error",
        "outcome_unknown"
      ],
      "type": "string"
    },
    "ValidationOutcome": {
      "enum": [
        "pass",
        "fail",
        "not_run",
        "error",
        "cancelled"
      ],
      "type": "string"
    },
    "ValidationStabilityV2": {
      "enum": [
        "stable",
        "flaky",
        "not_evaluated"
      ],
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.validation-run:v2",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_refs": {
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "type": "array"
    },
    "attempt": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "check_ref": {
      "$ref": "#/$defs/DocumentRef"
    },
    "completeness": {
      "$ref": "#/$defs/Completeness"
    },
    "diagnostic_ids": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "exit_code": {
      "format": "int32",
      "type": [
        "integer",
        "null"
      ]
    },
    "finished_at": {
      "format": "date-time",
      "type": [
        "string",
        "null"
      ]
    },
    "invocation": {
      "$ref": "#/$defs/TaskInvocationV2"
    },
    "not_run_reason": {
      "anyOf": [
        {
          "$ref": "#/$defs/NotRunReasonV2"
        },
        {
          "type": "null"
        }
      ]
    },
    "observed_tool": {
      "anyOf": [
        {
          "$ref": "#/$defs/ObservedTool"
        },
        {
          "type": "null"
        }
      ]
    },
    "outcome": {
      "$ref": "#/$defs/ValidationOutcome"
    },
    "phase": {
      "type": "string"
    },
    "plan_item_id": {
      "type": "string"
    },
    "process_start_state": {
      "$ref": "#/$defs/ProcessStartStateV2"
    },
    "project_id": {
      "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "result_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "schema_id": {
      "const": "star.validation-run",
      "type": "string"
    },
    "schema_version": {
      "const": 2,
      "type": "integer"
    },
    "stability": {
      "$ref": "#/$defs/ValidationStabilityV2"
    },
    "started_at": {
      "format": "date-time",
      "type": [
        "string",
        "null"
      ]
    },
    "subject_binding": {
      "$ref": "#/$defs/EvidenceSubjectBinding"
    },
    "termination_reason": {
      "anyOf": [
        {
          "$ref": "#/$defs/TerminationReason"
        },
        {
          "type": "null"
        }
      ]
    },
    "validation_plan_ref": {
      "$ref": "#/$defs/DocumentRef"
    },
    "validation_run_id": {
      "type": "string"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "validation_run_id",
    "revision",
    "validation_plan_ref",
    "check_ref",
    "subject_binding",
    "plan_item_id",
    "project_id",
    "phase",
    "attempt",
    "invocation",
    "process_start_state",
    "outcome",
    "completeness",
    "stability",
    "diagnostic_ids",
    "artifact_refs",
    "result_fingerprint"
  ],
  "title": "ValidationRunV2",
  "type": "object"
}