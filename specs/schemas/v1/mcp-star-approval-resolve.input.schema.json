{
  "$id": "urn:star-control:schema:star.mcp.star_approval_resolve.input:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "approval_id": {
      "pattern": "^apr_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "conditions": {
      "anyOf": [
        {
          "type": "object"
        },
        {
          "type": "null"
        }
      ]
    },
    "decision": {
      "enum": [
        "approve",
        "deny"
      ],
      "type": "string"
    },
    "reason": {
      "anyOf": [
        {
          "maxLength": 1000,
          "pattern": "^[^\\u0000]*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "scope_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "required": [
    "approval_id",
    "decision",
    "scope_hash"
  ],
  "type": "object"
}