{
  "$defs": {
    "ChangePlanStatus": {
      "enum": [
        "draft",
        "ready",
        "applied",
        "validated",
        "blocked",
        "abandoned"
      ],
      "type": "string"
    },
    "ChangeRecipeRef": {
      "additionalProperties": false,
      "properties": {
        "definition_fingerprint": {
          "$ref": "#/$defs/Sha256Hash"
        },
        "recipe_id": {
          "type": "string"
        },
        "recipe_version": {
          "type": "string"
        }
      },
      "required": [
        "recipe_id",
        "recipe_version",
        "definition_fingerprint"
      ],
      "type": "object"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.change-plan:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "change_plan_id": {
      "pattern": "^cpl_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "expected_paths": {
      "items": {
        "minLength": 1,
        "pattern": "^[^/\\\\:\\u0000]+(?:/[^/\\\\:\\u0000]+)*$",
        "type": "string"
      },
      "type": "array"
    },
    "finding_refs": {
      "items": {
        "pattern": "^fnd_[a-z2-7]{52}$",
        "type": "string"
      },
      "type": "array"
    },
    "parameters": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "permission_plan_ref": {
      "type": "string"
    },
    "preconditions": {
      "items": {
        "$ref": "#/$defs/Sha256Hash"
      },
      "type": "array"
    },
    "project_id": {
      "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "recipe_refs": {
      "items": {
        "$ref": "#/$defs/ChangeRecipeRef"
      },
      "type": "array"
    },
    "revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "risk": {
      "type": "string"
    },
    "schema_id": {
      "const": "star.change-plan",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    },
    "status": {
      "$ref": "#/$defs/ChangePlanStatus"
    },
    "target_workspace_snapshot_id": {
      "pattern": "^wsp_[a-z2-7]{52}$",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "type": "string"
    },
    "validation_plan_ref": {
      "type": "string"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "change_plan_id",
    "revision",
    "project_id",
    "target_workspace_snapshot_id",
    "finding_refs",
    "recipe_refs",
    "parameters",
    "expected_paths",
    "preconditions",
    "risk",
    "permission_plan_ref",
    "validation_plan_ref",
    "status",
    "created_at",
    "updated_at"
  ],
  "title": "ChangePlan",
  "type": "object"
}