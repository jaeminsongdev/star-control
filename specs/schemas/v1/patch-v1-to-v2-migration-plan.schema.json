{
  "$defs": {
    "DocumentRef": {
      "additionalProperties": false,
      "properties": {
        "document_id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "schema_id": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/Sha256Hash"
        }
      },
      "required": [
        "schema_id",
        "document_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "PatchV1ToV2MigrationEntry": {
      "additionalProperties": false,
      "properties": {
        "legacy_patch_set_ref": {
          "$ref": "#/$defs/DocumentRef"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "projected_patch_set_ref": {
          "$ref": "#/$defs/DocumentRef"
        }
      },
      "required": [
        "legacy_patch_set_ref",
        "projected_patch_set_ref",
        "limitations"
      ],
      "type": "object"
    },
    "Sha256Hash": {
      "description": "Contract representation of a SHA-256 digest.  The prefix is always present.",
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "$id": "urn:star-control:schema:star.patch-v1-to-v2-migration-plan:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "backup_required": {
      "type": "boolean"
    },
    "dry_run": {
      "type": "boolean"
    },
    "entries": {
      "items": {
        "$ref": "#/$defs/PatchV1ToV2MigrationEntry"
      },
      "type": "array"
    },
    "plan_fingerprint": {
      "$ref": "#/$defs/Sha256Hash"
    },
    "project_id": {
      "pattern": "^prj_[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "rollback_supported": {
      "type": "boolean"
    },
    "schema_id": {
      "const": "star.patch-v1-to-v2-migration-plan",
      "type": "string"
    },
    "schema_version": {
      "const": 1,
      "type": "integer"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "project_id",
    "entries",
    "dry_run",
    "backup_required",
    "rollback_supported",
    "plan_fingerprint"
  ],
  "title": "PatchV1ToV2MigrationPlan",
  "type": "object"
}