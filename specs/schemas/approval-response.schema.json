{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/approval-response.schema.json",
  "title": "Star-Control ApprovalResponse",
  "type": "object",
  "required": [
    "schema_version",
    "job_id",
    "stage",
    "task_id",
    "response",
    "reviewer",
    "responded_at",
    "reason"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "job_id": {
      "type": "string",
      "pattern": "^J-[0-9]{4,}$"
    },
    "stage": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "response": {
      "type": "string",
      "enum": [
        "approved",
        "rejected",
        "needs_changes",
        "cancelled"
      ]
    },
    "reviewer": {
      "type": "string"
    },
    "responded_at": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "allowed_next_stage": {
      "type": [
        "string",
        "null"
      ]
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
