{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/validation-decision.schema.json",
  "title": "Star-Control ValidationDecision",
  "type": "object",
  "required": [
    "schema_version",
    "job_id",
    "stage",
    "task_id",
    "decision",
    "source",
    "reasons",
    "diagnostics",
    "next_state"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "job_id": {
      "type": "string",
      "pattern": "^J-[0-9]{4,}$"
    },
    "stage": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "AUTO_PASS",
        "HUMAN_REVIEW",
        "BLOCK"
      ]
    },
    "source": {
      "type": "string"
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "next_state": {
      "type": "string",
      "enum": [
        "VALIDATED",
        "WAITING_APPROVAL",
        "BLOCKED",
        "FAILED"
      ]
    },
    "review_pack_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "approval_request_path": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
