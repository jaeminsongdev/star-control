{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/approval-request.schema.json",
  "title": "Star-Control ApprovalRequest",
  "type": "object",
  "required": [
    "schema_version",
    "job_id",
    "stage",
    "task_id",
    "decision",
    "reasons",
    "review_pack_path",
    "requested_at",
    "requested_by"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "job_id": {
      "type": "string",
      "pattern": "^J-[0-9]{4,}$"
    },
    "stage": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "HUMAN_REVIEW",
        "BLOCK"
      ]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "review_pack_path": {
      "type": "string"
    },
    "requested_at": {
      "type": "string"
    },
    "requested_by": {
      "type": "string"
    }
  }
}
