{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/review-pack-handoff.schema.json",
  "title": "Star-Control ReviewPackHandoff",
  "type": "object",
  "required": [
    "schema_version",
    "job_id",
    "stage",
    "task_id",
    "decision",
    "source_json_path",
    "source_markdown_path",
    "canonical_json_path",
    "canonical_markdown_path",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "job_id": {
      "type": "string",
      "pattern": "^J-[0-9]{4,}$"
    },
    "stage": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "HUMAN_REVIEW",
        "BLOCK"
      ]
    },
    "source_json_path": {
      "type": "string"
    },
    "source_markdown_path": {
      "type": "string"
    },
    "canonical_json_path": {
      "type": "string"
    },
    "canonical_markdown_path": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "questions_for_human": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
