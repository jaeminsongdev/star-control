{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/daemon-state.schema.json",
  "title": "Star-Control DaemonState",
  "type": "object",
  "required": [
    "schema_version",
    "daemon_id",
    "status",
    "queue",
    "active_jobs"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "daemon_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "reserved",
        "starting",
        "running",
        "stopping",
        "stopped",
        "error"
      ]
    },
    "queue": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "active_jobs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_error": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
