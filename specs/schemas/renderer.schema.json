{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://star-control.local/schemas/renderer.schema.json",
  "title": "Star-Control RendererSpec",
  "type": "object",
  "required": [
    "schema_version",
    "renderer_id",
    "description",
    "input_kind",
    "output_kind",
    "template"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "renderer_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*$"
    },
    "description": {
      "type": "string"
    },
    "input_kind": {
      "type": "string"
    },
    "output_kind": {
      "type": "string",
      "enum": [
        "markdown",
        "json",
        "plain_text"
      ]
    },
    "template": {
      "type": "object",
      "required": [
        "path",
        "engine"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "engine": {
          "type": "string",
          "enum": [
            "plain",
            "handlebars_like",
            "reserved"
          ]
        }
      }
    }
  }
}
